function renderAdminList(){
    const list=document.getElementById('adminList');list.innerHTML='';
    wines.forEach(w=>{
        const el=document.createElement('div');el.className='wine-admin-item';el.id=`wai-${w.id}`;
        el.innerHTML=`<div class="wai-top"><img class="wai-thumb" id="thumb-${w.id}" src="${w.image||''}" alt="" onerror="this.style.background='#3a2020';this.removeAttribute('src')"><div class="wai-name">${w.name}</div></div>
            <div class="wai-fields">
                <div class="wai-fld" style="grid-column:span 2"><label>Nome</label><input id="wn-${w.id}" value="${w.name}"></div>
                <div class="wai-fld"><label>Tipo</label><select id="wt-${w.id}">${['tinto','branco','rose','espumante'].map(t=>`<option ${w.type===t?'selected':''}>${t}</option>`).join('')}</select></div>
                <div class="wai-fld"><label>Ano</label><input id="wy-${w.id}" type="number" value="${w.year}"></div>
                <div class="wai-fld"><label>Origem</label><input id="wo-${w.id}" value="${w.origin}"></div>
                <div class="wai-fld"><label>Preço R$</label><input id="wp-${w.id}" type="number" step="0.01" value="${w.price}"></div>
                <div class="wai-fld"><label>Estoque</label><input id="ws-${w.id}" type="number" value="${w.stock}"></div>
                <div class="wai-fld"><label>Custo R$ (compra)</label><input id="wc-${w.id}" type="number" step="0.01" value="${w.custo||0}" placeholder="0,00"></div>
                <div class="wai-fld" style="grid-column:span 2"><label>Imagem — URL ou images/nome.jpg</label>
                    <input id="wi-${w.id}" value="${w.image||''}" oninput="prevThumb(${w.id})">
                    <img class="wai-img-preview" id="prev-${w.id}" src="${w.image||''}" onerror="this.style.display='none'" style="${w.image?'':'display:none'}"></div>
                <div class="wai-fld" style="grid-column:span 3"><label>Descrição</label><textarea id="wd-${w.id}">${w.description}</textarea></div>
            </div>
            <div style="text-align:right;margin-top:.5rem"><button class="btn-admin btn-del-wine" onclick="delWineAdmin(${w.id})">🗑️ Remover</button></div>`;
        list.appendChild(el);
    });
}
function prevThumb(id){const v=document.getElementById(`wi-${id}`).value;const p=document.getElementById(`prev-${id}`);p.src=v;p.style.display=v?'':'none';document.getElementById(`thumb-${id}`).src=v;}
function delWineAdmin(id){if(!confirm('Remover este vinho do Firebase?'))return;db.ref(`wines/${id}`).remove();toast('Vinho removido!');}
function addWineAdmin(){wines.push({id:nextId++,name:'Novo Vinho',type:'tinto',origin:'',year:new Date().getFullYear(),description:'',price:0,stock:0,image:''});renderAdminList();document.getElementById('adminList').lastElementChild?.scrollIntoView({behavior:'smooth'});}
async function applyAdmin(){
    const upd={};
    wines.map(w=>({
        ...w,
        name:       document.getElementById(`wn-${w.id}`)?.value||w.name,
        type:       document.getElementById(`wt-${w.id}`)?.value||w.type,
        year:    parseFloat(document.getElementById(`wy-${w.id}`)?.value) || w.year,
        origin:     document.getElementById(`wo-${w.id}`)?.value||w.origin,
        price:   parseFloat(document.getElementById(`wp-${w.id}`)?.value) || w.price,
        stock:   parseFloat(document.getElementById(`ws-${w.id}`)?.value) || 0,
        custo:   parseFloat(document.getElementById(`wc-${w.id}`)?.value) || 0,
        image:      document.getElementById(`wi-${w.id}`)?.value??w.image,
        description:document.getElementById(`wd-${w.id}`)?.value||w.description,
    })).forEach(w=>{ upd[`wines/${w.id}`]=w; });
    try{
        await db.ref().update(upd);
        // atualiza wines local imediatamente (sem esperar Firebase listener)
        const updated = wines.map(w=>({
            ...w,
            name:        document.getElementById(`wn-${w.id}`)?.value||w.name,
            type:        document.getElementById(`wt-${w.id}`)?.value||w.type,
            year:        parseFloat(document.getElementById(`wy-${w.id}`)?.value)||w.year,
            origin:      document.getElementById(`wo-${w.id}`)?.value||w.origin,
            price:       parseFloat(document.getElementById(`wp-${w.id}`)?.value)||w.price,
            stock:       parseFloat(document.getElementById(`ws-${w.id}`)?.value)||0,
            custo:       parseFloat(document.getElementById(`wc-${w.id}`)?.value)||0,
            image:       document.getElementById(`wi-${w.id}`)?.value??w.image,
            description: document.getElementById(`wd-${w.id}`)?.value||w.description,
        }));
        wines = updated;
        renderAdminList();
        toast('✅ Salvo! Preço de compra atualizado.');
    }
    catch(e){ toast('Erro: '+e.message,'err'); }
}


