<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🍷 VinotecaBR</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>

    <script>
    /* ╔══════════════════════════════════════════════════════════════════╗
       ║  PASSO 1 — Cole aqui as credenciais do seu projeto Firebase     ║
       ║  Veja o arquivo FIREBASE_SETUP.md para instruções completas     ║
       ╚══════════════════════════════════════════════════════════════════╝ */
    const FIREBASE_CONFIG = {
  apiKey: "AIzaSyBy7irmpOni2O3tCzfLwwqr2gRAt44EBIQ",
  authDomain: "vinotecabr-bfffd.firebaseapp.com",
  databaseURL: "https://vinotecabr-bfffd-default-rtdb.firebaseio.com/",
  projectId: "vinotecabr-bfffd",
  storageBucket: "vinotecabr-bfffd.firebasestorage.app",
  messagingSenderId: "852209724042",
  appId: "1:852209724042:web:b03dc7ee9776f452fe9b73",
  measurementId: "G-CMSZ826SDZ"
};

    /* ╔══════════════════════════════════════════════════════════════════╗
       ║  PASSO 2 — Dados da loja                                        ║
       ╚══════════════════════════════════════════════════════════════════╝ */
    const WHATSAPP_NUMBER = "5511965866812";
    const STORE_NAME      = "VinotecaBR";
    const ADMIN_PASSWORD  = "vinho123";

    // 🔐 CONTROLE DE ACESSO MENSAL
    // UNLOCK_CODE: contra-senha mensal para desbloquear o sistema
    // LOCK_DAY: dia do mês em que o sistema bloqueia (padrão: 5 dias após virada)
    const UNLOCK_CODE   = "libera2025";   // ← troque toda vez que renovar
    const LOCK_DAY      = 5;              // bloqueia no dia 5 de cada mês
    const PRODUTO_NOME  = "VinotecaBR Pro";


    // 🔑 TOKEN DE INSTALAÇÃO — único por cliente, gerado automaticamente
    // NÃO altere este valor após a instalação
    const APP_TOKEN = (()=>{
        let t = localStorage.getItem('app_install_token');
        if(!t){ t = 'tok_'+Date.now()+'_'+Math.random().toString(36).substr(2,9); localStorage.setItem('app_install_token',t); }
        return t;
    })();

    const VENDEDORES = ["Selecione o vendedor...","Eric","Monique"];

    /* ╔══════════════════════════════════════════════════════════════════╗
       ║  PASSO 3 — Catálogo inicial (só usado na PRIMEIRA abertura)     ║
       ║  Depois disso o estoque vive no Firebase.                       ║
       ╚══════════════════════════════════════════════════════════════════╝ */
    const WINES_INICIAL = [
        {id:1,name:"DV CATENA CABERNET MALBEC",               type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Catena Zapata.",      price:89.90, stock:12,image:"images/DV_CB_M_GIT.jpeg"},
        {id:2,name:"DV CATENA MALBEC MALBEC",                 type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Catena Zapata.",      price:104.90,stock:8, image:"images/DV_MB_MB_GIT.jpeg"},
        {id:3,name:"DV CATENA HISTORICO MALBEC PETIT VERDOT", type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Catena Zapata.",      price:164.90,stock:15,image:"images/DV_PETIT_VERDOT_GIT.jpeg"},
        {id:4,name:"EL ENEMIGO MALBEC",                       type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor El Enemigo.",         price:124.90,stock:6, image:"images/EL_MB_GIT.jpeg"},
        {id:5,name:"LUCA OLD VINE MALBEC",                    type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Luca (Laura Catena).",price:169.00,stock:6, image:"images/LUCA_MB_GIT.jpeg"},
        {id:6,name:"LUIGI BOSCA MALBEC",                      type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Bodega Luigi Bosca.", price:89.90, stock:18,image:"images/LUIGI_MB_GIT.jpeg"},
        {id:7,name:"NICASSIA VINEYARDS MALBEC",               type:"tinto", origin:"ARGENTINA",year:0,description:"Produtor Catena Zapata.",      price:69.90, stock:12,image:"images/NICASSIA_MB_GIT.jpeg"},
        {id:8,name:"SUSANA BALBO SIGNATURA TORRONTES",        type:"branco",origin:"ARGENTINA",year:0,description:"Produtor Susana Balbo.",       price:137.90,stock:6, image:"images/prosecco.jpg"}
    ];
    </script>

    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{--vinho:#7A2832;--vinho-dk:#4A1820;--ouro:#C9A84C;--ouro-lt:#E8D5A3;--creme:#FDF6EC;--dark:#1A1010;--ok:#2E7D32}
        body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--creme);min-height:100vh}

        #loadingScreen{position:fixed;inset:0;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;gap:1.5rem}
        .load-title{font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:var(--ouro-lt);letter-spacing:2px}
        .load-spinner{width:48px;height:48px;border-radius:50%;border:3px solid rgba(201,168,76,.2);border-top-color:var(--ouro);animation:spin .8s linear infinite}
        @keyframes spin{to{transform:rotate(360deg)}}
        .load-status{font-size:.85rem;color:rgba(201,168,76,.5)}

        #configAlert{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9998;align-items:center;justify-content:center;padding:1rem}
        #configAlert.show{display:flex}
        .config-box{background:#1a1010;border:2px solid var(--ouro);border-radius:16px;padding:2rem;max-width:580px;width:100%}
        .config-box h2{font-family:'Cormorant Garamond',serif;color:var(--ouro);font-size:1.6rem;margin-bottom:1rem}
        .config-box p,.config-box li{color:#c5b5b5;font-size:.9rem;line-height:1.8}
        .config-box ol{padding-left:1.4rem;margin-bottom:1rem}
        .config-box code{background:rgba(0,0,0,.4);padding:2px 7px;border-radius:4px;font-size:.82rem;color:var(--ouro-lt)}
        .config-box a{color:var(--ouro)}

        header{background:linear-gradient(160deg,var(--vinho-dk) 0%,var(--vinho) 60%,#8B3040 100%);padding:3rem 2rem 2.5rem;text-align:center;border-bottom:2px solid var(--ouro);position:relative;overflow:hidden}
        header::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='30' cy='30' r='1' fill='%23C9A84C' opacity='.15'/%3E%3C/svg%3E") repeat}
        h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:600;color:var(--ouro-lt);letter-spacing:2px;position:relative}
        .db-badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.72rem;font-family:'DM Sans',sans-serif;padding:.2rem .7rem;border-radius:20px;margin-left:.7rem;vertical-align:middle;font-weight:500}
        .db-badge.on{background:rgba(46,125,50,.3);color:#66BB6A;border:1px solid rgba(102,187,106,.25)}
        .db-badge.off{background:rgba(198,40,40,.3);color:#EF5350;border:1px solid rgba(239,83,80,.25)}
        .db-dot{width:6px;height:6px;border-radius:50%;background:currentColor}
        .subtitle{font-family:'Cormorant Garamond',serif;font-style:italic;color:rgba(232,213,163,.7);font-size:1.1rem;margin-top:.4rem;position:relative}

        .container{max-width:1400px;margin:0 auto;padding:2rem}
        .controls{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:2.5rem}
        .search-wrap{position:relative;flex:1;min-width:220px}
        .search-wrap input{width:100%;padding:.85rem 1rem .85rem 2.8rem;border:1.5px solid rgba(201,168,76,.3);border-radius:40px;background:rgba(255,255,255,.06);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.95rem;transition:.3s}
        .search-wrap input:focus{outline:none;border-color:var(--ouro);background:rgba(255,255,255,.1)}
        .search-wrap::before{content:'🔍';position:absolute;left:.9rem;top:50%;transform:translateY(-50%);font-size:1rem}
        .top-right{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}
        .btn-filter{padding:.5rem 1.1rem;border:1.5px solid rgba(201,168,76,.35);background:transparent;color:var(--ouro-lt);border-radius:20px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:500;transition:.25s}
        .btn-filter:hover,.btn-filter.active{background:var(--vinho);border-color:var(--ouro)}
        .btn-catalog{padding:.5rem 1.1rem;border:1.5px solid var(--ouro);background:rgba(201,168,76,.12);color:var(--ouro);border-radius:20px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:600;transition:.25s}
        .btn-catalog:hover{background:rgba(201,168,76,.25)}

        .cart-fab{position:fixed;top:1.5rem;right:1.5rem;width:58px;height:58px;background:var(--vinho);border:2px solid var(--ouro);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;cursor:pointer;z-index:900;box-shadow:0 4px 24px rgba(0,0,0,.45);transition:.3s}
        .cart-fab:hover{transform:scale(1.1)}
        .cart-badge{position:absolute;top:-4px;right:-4px;background:var(--ouro);color:var(--vinho-dk);width:22px;height:22px;border-radius:50%;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center}

        .wine-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:2rem}
        .wine-card{background:linear-gradient(145deg,rgba(255,255,255,.07) 0%,rgba(255,255,255,.03) 100%);border:1px solid rgba(201,168,76,.15);border-radius:16px;overflow:hidden;transition:.35s}
        .wine-card:hover{transform:translateY(-8px);border-color:rgba(201,168,76,.5);box-shadow:0 18px 40px rgba(0,0,0,.5)}
        .wine-img-wrap{position:relative;height:400px;overflow:hidden;background:#2a1a1a}
        .wine-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
        .wine-card:hover .wine-img-wrap img{transform:scale(1.05)}
        .no-img{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:rgba(201,168,76,.3);font-size:.85rem;gap:.5rem}
        .no-img-icon{font-size:3rem;opacity:.4}
        .type-badge{position:absolute;top:1rem;left:1rem;padding:.3rem .8rem;border-radius:12px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px}
        .type-tinto{background:#6B0000;color:#ffcccc}.type-branco{background:#F5F5DC;color:#444}.type-rose{background:#E8A4B8;color:#6B0030}.type-espumante{background:#C9A84C;color:#2a1a00}
        .btn-share-label{position:absolute;top:1rem;right:1rem;width:38px;height:38px;background:rgba(26,16,16,.75);border:1.5px solid var(--ouro);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;transition:.25s;backdrop-filter:blur(4px)}
        .btn-share-label:hover{background:var(--ouro);transform:scale(1.1)}
        .wine-body{padding:1.4rem}
        .wine-name{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--ouro-lt);margin-bottom:.3rem;line-height:1.3}
        .wine-meta{font-size:.82rem;color:#9e8e8e;margin-bottom:.7rem}
        .wine-desc{font-size:.9rem;color:#c5b5b5;line-height:1.55}
        .wine-footer{display:flex;justify-content:space-between;align-items:center;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(201,168,76,.2)}
        .price{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;color:var(--ouro)}
        .stock-info{text-align:right}.stock-label{font-size:.75rem;color:#888}.stock-val{font-weight:600;font-size:1rem}
        .s-ok{color:#66BB6A}.s-med{color:#FFA726}.s-low{color:#EF5350}
        .qty-row{display:flex;align-items:center;justify-content:center;gap:1rem;margin-top:1rem}
        .qty-btn{width:32px;height:32px;border-radius:50%;border:1.5px solid var(--ouro);background:transparent;color:var(--ouro);font-size:1.1rem;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center}
        .qty-btn:hover{background:var(--ouro);color:var(--vinho-dk)}
        .qty-val{font-size:1.2rem;font-weight:600;min-width:32px;text-align:center}
        .btn-add{width:100%;margin-top:.9rem;padding:.9rem;background:linear-gradient(135deg,var(--vinho) 0%,var(--vinho-dk) 100%);color:var(--ouro-lt);border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:.3s}
        .btn-add:hover:not(:disabled){opacity:.85;transform:translateY(-2px)}.btn-add:disabled{background:#3a3030;color:#666;cursor:not-allowed}

        .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);z-index:1000;align-items:center;justify-content:center;padding:1rem}
        .overlay.open{display:flex;animation:fadeIn .25s}
        @keyframes fadeIn{from{opacity:0}to{opacity:1}}
        .modal{background:#1e1212;border:1.5px solid var(--ouro);border-radius:18px;width:100%;max-width:580px;max-height:92vh;display:flex;flex-direction:column;animation:slideUp .3s}
        @keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
        .modal-hd{background:linear-gradient(135deg,var(--vinho) 0%,var(--vinho-dk) 100%);padding:1.3rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-radius:16px 16px 0 0}
        .modal-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--ouro-lt)}
        .btn-close{background:none;border:none;color:var(--creme);font-size:1.3rem;cursor:pointer;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:.2s}
        .btn-close:hover{background:rgba(255,255,255,.12);transform:rotate(90deg)}
        .cart-list{flex:1;overflow-y:auto;padding:1.2rem}
        .empty-msg{text-align:center;padding:3rem;color:#6b5b5b}
        .empty-msg div{font-size:3rem;margin-bottom:1rem}
        .cart-item{display:flex;gap:.9rem;padding:1rem;background:rgba(255,255,255,.04);border-radius:10px;margin-bottom:.8rem;border:1px solid rgba(201,168,76,.12)}
        .ci-img{width:72px;height:72px;object-fit:cover;border-radius:6px;border:1px solid rgba(201,168,76,.25);flex-shrink:0;background:#2a1a1a}
        .ci-info{flex:1}.ci-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--ouro-lt)}.ci-price{font-size:.9rem;color:#998888;margin:.2rem 0}
        .ci-row{display:flex;align-items:center;gap:.5rem;margin-top:.4rem}
        .ci-qbtn{width:22px;height:22px;border-radius:50%;border:1px solid var(--ouro);background:transparent;color:var(--ouro);cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center}
        .ci-subtotal{margin-left:auto;color:var(--ouro);font-weight:600;font-size:.95rem}
        .ci-del{color:#c0504d;cursor:pointer;font-size:1.1rem;transition:.2s;flex-shrink:0}
        .ci-del:hover{transform:scale(1.2)}
        .modal-ft{padding:1.3rem;border-top:1px solid rgba(122,40,50,.4)}
        .total-row{display:flex;justify-content:space-between;font-family:'Cormorant Garamond',serif;font-size:1.5rem;margin-bottom:1.1rem;color:var(--ouro-lt)}
        .total-row span:last-child{color:var(--ouro);font-weight:700}
        .order-fields{display:flex;flex-direction:column;gap:.7rem;margin-bottom:1rem}
        .fld label{display:block;font-size:.78rem;color:#9e8e8e;margin-bottom:.3rem;letter-spacing:.5px;text-transform:uppercase}
        .fld input,.fld select{width:100%;padding:.7rem .9rem;border:1.5px solid rgba(122,40,50,.5);border-radius:8px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.95rem}
        .fld input:focus,.fld select:focus{outline:none;border-color:var(--ouro)}
        .fld select option{background:#1e1010}
        .fld-row{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}
        @media(max-width:480px){.fld-row{grid-template-columns:1fr}}
        .btn-wpp{width:100%;padding:1rem;background:linear-gradient(135deg,#25D366 0%,#1a9e50 100%);color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:1.05rem;font-weight:700;cursor:pointer;transition:.3s;display:flex;align-items:center;justify-content:center;gap:.6rem}
        .btn-wpp:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(37,211,102,.35)}
        .btn-wpp:disabled{background:#3a3030;color:#666;cursor:not-allowed;transform:none;box-shadow:none}

        .label-preview-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:1500;align-items:center;justify-content:center;padding:1rem;flex-direction:column;gap:1rem}
        .label-preview-overlay.open{display:flex}
        .label-preview-img{max-width:380px;width:100%;border-radius:12px;box-shadow:0 8px 40px rgba(0,0,0,.6)}
        .label-preview-actions{display:flex;gap:.8rem;flex-wrap:wrap;justify-content:center}
        .btn-lp{padding:.8rem 1.4rem;border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:1rem;cursor:pointer;border:none;transition:.3s;display:flex;align-items:center;gap:.5rem}
        .btn-lp-wpp{background:linear-gradient(135deg,#25D366,#1a9e50);color:#fff}.btn-lp-dl{background:var(--ouro);color:var(--vinho-dk)}.btn-lp-cl{background:rgba(255,255,255,.1);color:var(--creme);border:1px solid rgba(255,255,255,.2)}
        .btn-lp:hover{transform:translateY(-2px);opacity:.9}
        .generating-msg{color:var(--ouro-lt);font-family:'Cormorant Garamond',serif;font-size:1.3rem;display:none}
        .generating-msg.show{display:block}

        .catalog-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:1200;overflow-y:auto;padding:2rem 1rem}
        .catalog-overlay.open{display:block}
        .catalog-wrap{max-width:900px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden}
        .catalog-toolbar{background:#4A1820;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:10}
        .catalog-toolbar span{color:#E8D5A3;font-family:'Cormorant Garamond',serif;font-size:1.3rem}
        .catalog-toolbar-btns{display:flex;gap:.6rem}
        .btn-print{padding:.5rem 1.2rem;background:#C9A84C;color:#2a1a00;border:none;border-radius:8px;font-weight:700;font-size:.9rem;cursor:pointer}
        .btn-close-cat{padding:.5rem 1rem;background:transparent;color:#E8D5A3;border:1px solid rgba(232,213,163,.4);border-radius:8px;font-size:.9rem;cursor:pointer}
        .catalog-page{padding:2.5rem;background:#fff;color:#222}
        .catalog-header{text-align:center;border-bottom:3px double #7A2832;padding-bottom:1.5rem;margin-bottom:2rem}
        .catalog-header h1{font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:#4A1820;letter-spacing:2px}
        .catalog-header p{color:#888;font-style:italic;font-size:1rem;margin-top:.3rem}
        .catalog-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
        .label-card{border:1.5px solid #C9A84C;border-radius:10px;overflow:hidden;page-break-inside:avoid;break-inside:avoid}
        .label-img{width:100%;height:160px;object-fit:cover;background:#f5f0e8;display:block}
        .label-img-placeholder{width:100%;height:160px;background:linear-gradient(135deg,#f5f0e8,#ede0cc);display:flex;align-items:center;justify-content:center;font-size:3rem;color:#C9A84C;opacity:.4}
        .label-body{padding:.65rem .85rem}
        .label-type-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem}
        .label-badge{padding:.2rem .7rem;border-radius:10px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px}
        .lb-tinto{background:#f0d0d0;color:#6B0000}.lb-branco{background:#f5f5dc;color:#555;border:1px solid #ccc}.lb-rose{background:#fce4ec;color:#880e4f}.lb-espumante{background:#fff8dc;color:#5d4037;border:1px solid #e6c46a}
        .label-year{font-size:.8rem;color:#999}
        .label-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:600;color:#4A1820;line-height:1.2;margin-bottom:.15rem}
        .label-origin{font-size:.8rem;color:#888;margin-bottom:.5rem}
        .label-desc{font-size:.82rem;color:#555;line-height:1.5;margin-bottom:.7rem;border-top:1px solid #f0e8d8;padding-top:.7rem}
        .label-price-row{display:flex;justify-content:space-between;align-items:center}
        .label-price{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:700;color:#C9A84C}
        .label-stock-badge{font-size:.75rem;padding:.2rem .6rem;border-radius:10px;font-weight:600}
        .lsb-ok{background:#e8f5e9;color:#2E7D32}.lsb-med{background:#fff3e0;color:#E65100}.lsb-low{background:#ffebee;color:#c62828}
        .label-card-footer{display:flex;justify-content:flex-end;padding:.6rem 1rem .8rem;background:#fdf6ec;border-top:1px solid rgba(201,168,76,.2)}
        .btn-share-catalog{padding:.4rem 1rem;background:linear-gradient(135deg,#25D366,#1a9e50);color:#fff;border:none;border-radius:20px;font-size:.8rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:.4rem}
        .catalog-footer{text-align:center;margin-top:2rem;padding-top:1rem;border-top:1px solid #e0d0c0;font-size:.8rem;color:#bbb}

        /* ── HISTÓRICO ── */
        .orders-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(6px);z-index:1100;align-items:flex-start;justify-content:center;padding:1rem;overflow-y:auto}
        .orders-overlay.open{display:flex}
        .orders-panel{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:860px;margin:auto;overflow:hidden}
        .orders-hd{background:var(--vinho-dk);padding:1.2rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3)}
        .orders-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro)}
        .orders-body{padding:1.5rem;max-height:75vh;overflow-y:auto}
        .order-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.15);border-radius:10px;padding:1rem;margin-bottom:.8rem}
        .order-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.6rem;flex-wrap:wrap;gap:.5rem}
        .order-meta{font-size:.8rem;color:#9e8e8e;margin-top:.2rem}
        .order-total-badge{background:rgba(201,168,76,.15);color:var(--ouro);padding:.2rem .7rem;border-radius:20px;font-size:.85rem;font-weight:600;white-space:nowrap}
        .order-items{font-size:.85rem;color:#c5b5b5;line-height:1.7}
        .order-vendedor{display:inline-block;background:rgba(122,40,50,.4);color:var(--ouro-lt);padding:.15rem .6rem;border-radius:10px;font-size:.75rem;margin-bottom:.3rem}
        .empty-orders{text-align:center;padding:3rem;color:#6b5b5b}

        .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(80px);padding:.9rem 1.8rem;border-radius:40px;font-size:.95rem;font-weight:500;z-index:3000;opacity:0;transition:.35s;white-space:nowrap}
        .toast.show{transform:translateX(-50%) translateY(0);opacity:1}
        .toast.ok{background:var(--ok);color:#fff}.toast.err{background:#c62828;color:#fff}.toast.info{background:var(--vinho);color:var(--ouro-lt)}

        .admin-trigger{position:fixed;bottom:1.5rem;left:1.5rem;background:rgba(0,0,0,.6);border:1px solid rgba(201,168,76,.2);color:rgba(201,168,76,.4);padding:.5rem .9rem;border-radius:8px;font-size:.75rem;cursor:pointer;z-index:100;transition:.2s}
        .admin-trigger:hover{color:var(--ouro);border-color:var(--ouro)}
        .admin-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(6px);z-index:1100;align-items:flex-start;justify-content:center;padding:1rem;overflow-y:auto}
        .admin-overlay.open{display:flex}
        .admin-panel{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:940px;margin:auto;overflow:hidden}
        .admin-hd{background:var(--vinho-dk);padding:1.2rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3)}
        .admin-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro)}
        .admin-body{padding:1.5rem}
        .admin-note{background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:8px;padding:1rem;font-size:.85rem;color:#c5b5b5;margin-bottom:1.5rem;line-height:1.8}
        .admin-note strong{color:var(--ouro-lt)}.admin-note code{background:rgba(0,0,0,.3);padding:1px 5px;border-radius:3px;font-size:.8rem}
        .wine-admin-list{display:flex;flex-direction:column;gap:1rem}
        .wine-admin-item{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.15);border-radius:10px;padding:1rem}
        .wai-top{display:flex;gap:.8rem;align-items:center;margin-bottom:.8rem}
        .wai-thumb{width:60px;height:60px;object-fit:cover;border-radius:6px;border:1px solid rgba(201,168,76,.3);background:#2a1a1a;flex-shrink:0}
        .wai-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--ouro-lt)}
        .wai-fields{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.6rem}
        .wai-fld label{display:block;font-size:.75rem;color:#888;margin-bottom:.25rem}
        .wai-fld input,.wai-fld select,.wai-fld textarea{width:100%;padding:.55rem .7rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .wai-fld textarea{resize:vertical;height:60px}
        .wai-fld input:focus,.wai-fld select:focus,.wai-fld textarea:focus{outline:none;border-color:var(--ouro)}
        .wai-fld select option{background:#1a1010}
        .wai-img-preview{margin-top:.5rem;width:100%;height:80px;object-fit:cover;border-radius:6px;background:#2a1a1a;display:block}
        .admin-actions{display:flex;gap:.8rem;margin-top:1.5rem;flex-wrap:wrap}
        .btn-admin{padding:.75rem 1.4rem;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.9rem;cursor:pointer;transition:.2s;border:none}
        .btn-save{background:var(--ok);color:#fff}.btn-add-wine{background:var(--vinho);color:var(--ouro-lt)}.btn-del-wine{background:#c62828;color:#fff;margin-left:auto}
        .login-box{padding:2.5rem;text-align:center}
        .login-box h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro);margin-bottom:1.2rem}
        .login-box input{width:100%;max-width:280px;padding:.8rem 1rem;border-radius:8px;border:1.5px solid rgba(201,168,76,.3);background:rgba(255,255,255,.05);color:var(--creme);font-size:1rem;display:block;margin:0 auto 1rem;text-align:center;letter-spacing:4px}
        .login-box input:focus{outline:none;border-color:var(--ouro)}
        .btn-login{padding:.7rem 2rem;background:var(--vinho);color:var(--ouro-lt);border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer}

        
        /* ══════════════════════════════════════
           PAINEL FINANCEIRO
        ══════════════════════════════════════ */
        .fin-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(6px);z-index:1150;align-items:flex-start;justify-content:center;padding:1rem;overflow-y:auto}
        .fin-overlay.open{display:flex}
        .fin-panel{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:1000px;margin:auto;overflow:hidden}
        .fin-hd{background:var(--vinho-dk);padding:1.2rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3)}
        .fin-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro)}

        /* tabs */
        .fin-tabs{display:flex;border-bottom:1px solid rgba(201,168,76,.2);background:rgba(0,0,0,.2)}
        .fin-tab{padding:.8rem 1.3rem;background:transparent;border:none;color:#9e8e8e;font-family:'DM Sans',sans-serif;font-size:.88rem;font-weight:500;cursor:pointer;transition:.2s;border-bottom:2px solid transparent}
        .fin-tab:hover{color:var(--ouro-lt)}
        .fin-tab.active{color:var(--ouro);border-bottom-color:var(--ouro)}
        .fin-body{padding:1.5rem;max-height:80vh;overflow-y:auto}

        /* KPI cards */
        .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:1.5rem}
        .kpi-card{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.15);border-radius:10px;padding:1rem 1.2rem}
        .kpi-label{font-size:.75rem;color:#9e8e8e;margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.5px}
        .kpi-value{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;color:var(--ouro)}
        .kpi-value.pos{color:#66BB6A}.kpi-value.neg{color:#EF5350}

        /* tabela financeira */
        .fin-table{width:100%;border-collapse:collapse;font-size:.85rem}
        .fin-table th{text-align:left;padding:.6rem .8rem;font-size:.75rem;color:#9e8e8e;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid rgba(201,168,76,.2);font-weight:500}
        .fin-table td{padding:.7rem .8rem;border-bottom:1px solid rgba(255,255,255,.04);color:#c5b5b5;vertical-align:middle}
        .fin-table tr:last-child td{border-bottom:none}
        .fin-table tr:hover td{background:rgba(255,255,255,.03)}
        .badge-margin{display:inline-block;padding:.15rem .55rem;border-radius:8px;font-size:.75rem;font-weight:600}
        .bm-ok{background:rgba(46,125,50,.25);color:#66BB6A}
        .bm-warn{background:rgba(230,81,0,.25);color:#FFA726}
        .bm-bad{background:rgba(198,40,40,.25);color:#EF5350}

        /* formulário de despesa */
        .desp-form{display:grid;grid-template-columns:1fr 1fr auto auto;gap:.6rem;align-items:end;margin-bottom:1.2rem;background:rgba(255,255,255,.04);padding:1rem;border-radius:10px;border:1px solid rgba(201,168,76,.12)}
        @media(max-width:640px){.desp-form{grid-template-columns:1fr}}
        .desp-form label{display:block;font-size:.75rem;color:#888;margin-bottom:.25rem}
        .desp-form input,.desp-form select{width:100%;padding:.55rem .7rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .desp-form input:focus,.desp-form select:focus{outline:none;border-color:var(--ouro)}
        .desp-form select option{background:#1a1010}
        .btn-add-desp{padding:.55rem 1.1rem;background:var(--ok);color:#fff;border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.85rem;cursor:pointer;white-space:nowrap}
        .btn-del-desp{background:transparent;border:none;color:#c0504d;cursor:pointer;font-size:1rem;padding:.2rem .4rem}

        /* comissões */
        .com-filter{display:flex;gap:.7rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1.2rem;background:rgba(255,255,255,.04);padding:1rem;border-radius:10px;border:1px solid rgba(201,168,76,.12)}
        .com-filter label{display:block;font-size:.75rem;color:#888;margin-bottom:.25rem}
        .com-filter input,.com-filter select{padding:.55rem .7rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .com-filter input:focus{outline:none;border-color:var(--ouro)}
        .btn-calc-com{padding:.55rem 1.1rem;background:var(--vinho);color:var(--ouro-lt);border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.85rem;cursor:pointer}
        .com-pct-row{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap}
        .com-pct-row label{font-size:.82rem;color:#9e8e8e}
        .com-pct-row input{width:70px;padding:.4rem .6rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .com-pct-row button{padding:.4rem .9rem;background:var(--ok);color:#fff;border:none;border-radius:6px;font-size:.82rem;font-weight:600;cursor:pointer}
        .com-vendor-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.15);border-radius:10px;padding:1rem 1.2rem;margin-bottom:.8rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.8rem}
        .com-vendor-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--ouro-lt)}
        .com-vendor-stats{display:flex;gap:1.5rem;flex-wrap:wrap}
        .com-stat{text-align:center}
        .com-stat-lbl{font-size:.72rem;color:#888;text-transform:uppercase;letter-spacing:.4px}
        .com-stat-val{font-size:1.1rem;font-weight:600;color:var(--creme)}
        .com-stat-val.gold{color:var(--ouro)}
        .com-stat-val.green{color:#66BB6A}


        /* ══ PEDIDOS EM ABERTO ══ */
        .ped-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(6px);z-index:1150;align-items:flex-start;justify-content:center;padding:1rem;overflow-y:auto}
        .ped-overlay.open{display:flex}
        .ped-panel{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:1000px;margin:auto;overflow:hidden}
        .ped-hd{background:var(--vinho-dk);padding:1.2rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3)}
        .ped-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro)}
        .ped-filter{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;padding:1rem 1.5rem;border-bottom:1px solid rgba(201,168,76,.12);background:rgba(0,0,0,.15)}
        .ped-filter label{font-size:.78rem;color:#9e8e8e}
        .ped-filter select,.ped-filter input{padding:.45rem .7rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .ped-filter select option{background:#1a1010}
        .btn-ped-refresh{padding:.45rem 1rem;background:rgba(201,168,76,.15);color:var(--ouro);border:1px solid rgba(201,168,76,.3);border-radius:6px;font-size:.82rem;font-weight:600;cursor:pointer}
        .ped-body{padding:1.2rem;max-height:78vh;overflow-y:auto}
        .ped-kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.8rem;margin-bottom:1.2rem}
        .ped-grid{display:flex;flex-direction:column;gap:.7rem}
        .ped-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.12);border-radius:10px;padding:1rem 1.2rem;display:grid;grid-template-columns:1fr auto;gap:.8rem;align-items:start}
        .ped-card.pago{border-color:rgba(46,125,50,.3);background:rgba(46,125,50,.05)}
        .ped-card-left{}
        .ped-card-top{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin-bottom:.4rem}
        .ped-status{display:inline-block;padding:.2rem .7rem;border-radius:12px;font-size:.72rem;font-weight:700;letter-spacing:.5px}
        .ps-aberto{background:rgba(230,81,0,.25);color:#FFA726;border:1px solid rgba(230,81,0,.3)}
        .ps-pago  {background:rgba(46,125,50,.25);color:#66BB6A;border:1px solid rgba(46,125,50,.3)}
        .ped-vendedor{font-size:.78rem;background:rgba(122,40,50,.35);color:var(--ouro-lt);padding:.15rem .6rem;border-radius:8px}
        .ped-meta{font-size:.8rem;color:#9e8e8e;margin-bottom:.35rem}
        .ped-cliente{font-size:.88rem;color:var(--creme);font-weight:500}
        .ped-itens{font-size:.8rem;color:#c5b5b5;margin-top:.4rem;line-height:1.6}
        .ped-card-right{display:flex;flex-direction:column;align-items:flex-end;gap:.6rem}
        .ped-total{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;color:var(--ouro)}
        .btn-pagar{padding:.5rem 1rem;background:linear-gradient(135deg,var(--ok),#1B5E20);color:#fff;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;transition:.25s;white-space:nowrap}
        .btn-pagar:hover{opacity:.85;transform:translateY(-1px)}
        .btn-reabrir{padding:.5rem 1rem;background:rgba(230,81,0,.2);color:#FFA726;border:1px solid rgba(230,81,0,.3);border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;white-space:nowrap}
        .ped-empty{text-align:center;padding:3rem;color:#6b5b5b}


        /* ══ MENU LATERAL ADMIN ══ */
        .admin-menu{display:flex;flex-direction:column;gap:0;border-bottom:1px solid rgba(201,168,76,.15);margin-bottom:1.2rem}
        .admin-menu-btn{display:flex;align-items:center;gap:.7rem;padding:.85rem 1.2rem;background:transparent;border:none;border-top:1px solid rgba(201,168,76,.1);color:#c5b5b5;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:500;cursor:pointer;transition:.2s;text-align:left;width:100%}
        .admin-menu-btn:hover{background:rgba(201,168,76,.08);color:var(--ouro-lt)}
        .admin-menu-btn .menu-icon{font-size:1.1rem;width:22px;text-align:center;flex-shrink:0}
        .admin-menu-btn.danger{color:#EF9595}.admin-menu-btn.danger:hover{background:rgba(198,40,40,.12);color:#EF5350}
        .admin-menu-section{padding:.5rem 1.2rem .3rem;font-size:.7rem;color:#6b5b5b;text-transform:uppercase;letter-spacing:1px}
        /* layout dois painéis */
        .admin-inner{display:grid;grid-template-columns:220px 1fr;min-height:400px}
        @media(max-width:640px){.admin-inner{grid-template-columns:1fr}}
        .admin-sidebar{border-right:1px solid rgba(201,168,76,.15);padding:.5rem 0}
        .admin-main{overflow:hidden}
        /* com-imposto row */
        .com-imp-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.8rem;flex-wrap:wrap}
        .com-imp-row label{font-size:.82rem;color:#9e8e8e}
        .com-imp-row input{width:70px;padding:.4rem .6rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .com-imp-row button{padding:.4rem .9rem;background:var(--ok);color:#fff;border:none;border-radius:6px;font-size:.82rem;font-weight:600;cursor:pointer}


        /* ══ MODAL EDITAR PEDIDO ══ */
        .edit-ped-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(6px);z-index:1300;align-items:center;justify-content:center;padding:1rem}
        .edit-ped-overlay.open{display:flex;animation:fadeIn .2s}
        .edit-ped-modal{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:600px;max-height:90vh;overflow-y:auto}
        .edit-ped-hd{background:var(--vinho-dk);padding:1.1rem 1.4rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3);position:sticky;top:0;z-index:5}
        .edit-ped-hd h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--ouro)}
        .edit-ped-body{padding:1.4rem;display:flex;flex-direction:column;gap:.9rem}
        .ep-fld label{display:block;font-size:.75rem;color:#9e8e8e;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.4px}
        .ep-fld input,.ep-fld select{width:100%;padding:.65rem .85rem;border:1.5px solid rgba(122,40,50,.5);border-radius:8px;background:rgba(255,255,255,.06);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.9rem}
        .ep-fld input:focus,.ep-fld select:focus{outline:none;border-color:var(--ouro)}
        .ep-fld select option{background:#1a1010}
        .ep-row{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}
        @media(max-width:480px){.ep-row{grid-template-columns:1fr}}
        /* itens editáveis */
        .ep-itens-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:.5rem}
        .ep-item-row{display:grid;grid-template-columns:1fr 60px 90px 32px;gap:.4rem;align-items:center}
        .ep-item-row input{padding:.45rem .6rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .ep-item-row input:focus{outline:none;border-color:var(--ouro)}
        .ep-item-row label{font-size:.7rem;color:#888;display:block;margin-bottom:.2rem}
        .btn-ep-del-item{width:28px;height:28px;background:rgba(198,40,40,.2);border:1px solid rgba(198,40,40,.3);color:#EF5350;border-radius:6px;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;align-self:flex-end;margin-bottom:0}
        .btn-ep-del-item:hover{background:rgba(198,40,40,.4)}
        .btn-ep-add-item{padding:.45rem .9rem;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.3);color:var(--ouro);border-radius:6px;font-size:.8rem;font-weight:600;cursor:pointer;margin-top:.2rem}
        .edit-ped-footer{padding:1rem 1.4rem;border-top:1px solid rgba(201,168,76,.15);display:flex;gap:.7rem;justify-content:flex-end}
        .btn-ep-save{padding:.7rem 1.4rem;background:var(--ok);color:#fff;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.9rem;cursor:pointer}
        .btn-ep-cancel{padding:.7rem 1.1rem;background:transparent;border:1px solid rgba(201,168,76,.25);color:var(--ouro-lt);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.9rem;cursor:pointer}
        /* botão excluir nos cards de pedido */
        .btn-excluir-ped{padding:.5rem .85rem;background:rgba(198,40,40,.15);color:#EF5350;border:1px solid rgba(198,40,40,.3);border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;transition:.2s;white-space:nowrap}
        .btn-excluir-ped:hover{background:rgba(198,40,40,.35)}
        .btn-editar-ped{padding:.5rem .85rem;background:rgba(201,168,76,.12);color:var(--ouro);border:1px solid rgba(201,168,76,.3);border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;transition:.2s;white-space:nowrap}
        .btn-editar-ped:hover{background:rgba(201,168,76,.25)}
        .ped-card-actions{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.6rem}


        /* ══ PAINEL ADMIN UNIFICADO ══ */
        .admin-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);backdrop-filter:blur(5px);z-index:1100;align-items:flex-start;justify-content:center;padding:.8rem;overflow-y:auto}
        .admin-overlay.open{display:flex;animation:fadeIn .25s}
        .admin-panel{background:#1a1010;border:1.5px solid var(--ouro);border-radius:16px;width:100%;max-width:1160px;margin:auto;overflow:hidden;display:flex;flex-direction:column;min-height:500px;max-height:92vh}
        .admin-hd{background:var(--vinho-dk);padding:1rem 1.4rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,.3);flex-shrink:0}
        .admin-hd h2{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--ouro)}
        .admin-hd-right{display:flex;align-items:center;gap:.8rem}
        .admin-hd-context{font-size:.82rem;color:rgba(232,213,163,.6);font-family:'Cormorant Garamond',serif;font-style:italic}
        .login-box{padding:2.5rem;text-align:center}
        .login-box h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro);margin-bottom:1.2rem}
        .login-box input{width:100%;max-width:280px;padding:.8rem 1rem;border-radius:8px;border:1.5px solid rgba(201,168,76,.3);background:rgba(255,255,255,.05);color:var(--creme);font-size:1rem;display:block;margin:0 auto 1rem;text-align:center;letter-spacing:4px}
        .login-box input:focus{outline:none;border-color:var(--ouro)}
        .btn-login{padding:.7rem 2rem;background:var(--vinho);color:var(--ouro-lt);border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer}
        /* inner layout */
        .admin-inner{display:flex;flex:1;overflow:hidden;min-height:0}
        .admin-sidebar{width:210px;flex-shrink:0;border-right:1px solid rgba(201,168,76,.15);overflow-y:auto;background:rgba(0,0,0,.15)}
        @media(max-width:640px){.admin-inner{flex-direction:column}.admin-sidebar{width:100%;border-right:none;border-bottom:1px solid rgba(201,168,76,.15)}}
        .admin-main{flex:1;overflow-y:auto;min-height:0}
        /* sidebar */
        .adm-section-lbl{padding:.55rem 1rem .25rem;font-size:.68rem;color:#6b5b5b;text-transform:uppercase;letter-spacing:1px}
        .adm-nav-btn{display:flex;align-items:center;gap:.6rem;width:100%;padding:.75rem 1rem;background:transparent;border:none;color:#c5b5b5;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:.15s;text-align:left;border-left:3px solid transparent}
        .adm-nav-btn:hover{background:rgba(201,168,76,.07);color:var(--ouro-lt)}
        .adm-nav-btn.active{background:rgba(201,168,76,.1);color:var(--ouro);border-left-color:var(--ouro)}
        .adm-nav-btn .mi{font-size:1rem;width:20px;text-align:center;flex-shrink:0}
        /* sections */
        .admin-section{display:none;padding:1.3rem;animation:fadeIn .2s}
        .admin-section.active{display:block}
        .admin-note{background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:8px;padding:.9rem 1rem;font-size:.83rem;color:#c5b5b5;margin-bottom:1.2rem;line-height:1.7}
        .admin-note strong{color:var(--ouro-lt)}.admin-note code{background:rgba(0,0,0,.3);padding:1px 5px;border-radius:3px;font-size:.78rem}
        /* wine list */
        .wine-admin-list{display:flex;flex-direction:column;gap:.9rem}
        .wine-admin-item{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.12);border-radius:10px;padding:.9rem}
        .wai-top{display:flex;gap:.7rem;align-items:center;margin-bottom:.7rem}
        .wai-thumb{width:54px;height:54px;object-fit:cover;border-radius:6px;border:1px solid rgba(201,168,76,.25);background:#2a1a1a;flex-shrink:0}
        .wai-name{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--ouro-lt)}
        .wai-fields{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.55rem}
        .wai-fld label{display:block;font-size:.72rem;color:#888;margin-bottom:.2rem}
        .wai-fld input,.wai-fld select,.wai-fld textarea{width:100%;padding:.5rem .65rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .wai-fld textarea{resize:vertical;height:56px}
        .wai-fld input:focus,.wai-fld select:focus,.wai-fld textarea:focus{outline:none;border-color:var(--ouro)}
        .wai-fld select option{background:#1a1010}
        .wai-img-preview{margin-top:.4rem;width:100%;height:72px;object-fit:cover;border-radius:6px;background:#2a1a1a;display:block}
        .admin-actions{display:flex;gap:.6rem;margin-top:1.1rem;flex-wrap:wrap}
        .btn-admin{padding:.65rem 1.2rem;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.85rem;cursor:pointer;transition:.2s;border:none}
        .btn-save{background:var(--ok);color:#fff}.btn-add-wine{background:var(--vinho);color:var(--ouro-lt)}.btn-del-wine{background:#c62828;color:#fff;margin-left:auto}
        /* financeiro dentro do admin */
        .fin-tabs{display:flex;border-bottom:1px solid rgba(201,168,76,.2);margin-bottom:1rem}
        .fin-tab{padding:.65rem 1.1rem;background:transparent;border:none;color:#9e8e8e;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:.2s;border-bottom:2px solid transparent}
        .fin-tab:hover{color:var(--ouro-lt)}
        .fin-tab.active{color:var(--ouro);border-bottom-color:var(--ouro)}
        .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.8rem;margin-bottom:1.2rem}
        .kpi-card{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.12);border-radius:10px;padding:.9rem 1rem}
        .kpi-label{font-size:.72rem;color:#9e8e8e;margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.4px}
        .kpi-value{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--ouro)}
        .kpi-value.pos{color:#66BB6A}.kpi-value.neg{color:#EF5350}.kpi-value.green{color:#66BB6A}
        .fin-table{width:100%;border-collapse:collapse;font-size:.82rem}
        .fin-table th{text-align:left;padding:.55rem .7rem;font-size:.72rem;color:#9e8e8e;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid rgba(201,168,76,.2);font-weight:500}
        .fin-table td{padding:.65rem .7rem;border-bottom:1px solid rgba(255,255,255,.04);color:#c5b5b5}
        .fin-table tr:hover td{background:rgba(255,255,255,.03)}
        .badge-margin{display:inline-block;padding:.15rem .5rem;border-radius:8px;font-size:.72rem;font-weight:600}
        .bm-ok{background:rgba(46,125,50,.25);color:#66BB6A}.bm-warn{background:rgba(230,81,0,.25);color:#FFA726}.bm-bad{background:rgba(198,40,40,.25);color:#EF5350}
        .desp-form{display:grid;grid-template-columns:1fr 1fr auto auto;gap:.55rem;align-items:end;margin-bottom:1rem;background:rgba(255,255,255,.04);padding:.9rem;border-radius:10px;border:1px solid rgba(201,168,76,.1)}
        @media(max-width:700px){.desp-form{grid-template-columns:1fr}}
        .desp-form label{display:block;font-size:.72rem;color:#888;margin-bottom:.2rem}
        .desp-form input,.desp-form select{width:100%;padding:.5rem .65rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .desp-form input:focus,.desp-form select:focus{outline:none;border-color:var(--ouro)}
        .desp-form select option{background:#1a1010}
        .btn-add-desp{padding:.5rem 1rem;background:var(--ok);color:#fff;border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.82rem;cursor:pointer;white-space:nowrap}
        .btn-del-desp{background:transparent;border:none;color:#c0504d;cursor:pointer;font-size:1rem;padding:.2rem .4rem}
        .com-config-row{display:flex;gap:1.2rem;flex-wrap:wrap;margin-bottom:1rem;background:rgba(255,255,255,.04);padding:.9rem;border-radius:10px;border:1px solid rgba(201,168,76,.1);align-items:flex-end}
        .com-config-row label{display:block;font-size:.72rem;color:#888;margin-bottom:.25rem}
        .com-config-row input{width:80px;padding:.5rem .65rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.85rem}
        .com-config-row input:focus{outline:none;border-color:var(--ouro)}
        .com-filter{display:flex;gap:.6rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1rem;background:rgba(255,255,255,.04);padding:.9rem;border-radius:10px;border:1px solid rgba(201,168,76,.1)}
        .com-filter label{display:block;font-size:.72rem;color:#888;margin-bottom:.25rem}
        .com-filter input,.com-filter select{padding:.5rem .65rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .com-filter input:focus{outline:none;border-color:var(--ouro)}
        .btn-calc-com{padding:.5rem 1rem;background:var(--vinho);color:var(--ouro-lt);border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.82rem;cursor:pointer}
        .com-vendor-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.12);border-radius:10px;padding:.9rem 1rem;margin-bottom:.7rem}
        .com-vendor-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--ouro-lt);margin-bottom:.6rem}
        .com-vendor-stats{display:flex;gap:1.2rem;flex-wrap:wrap}
        .com-stat{text-align:center}
        .com-stat-lbl{font-size:.7rem;color:#888;text-transform:uppercase;letter-spacing:.4px}
        .com-stat-val{font-size:1rem;font-weight:600;color:var(--creme)}
        .com-stat-val.gold{color:var(--ouro)}.com-stat-val.green{color:#66BB6A}
        /* pedidos dentro do admin */
        .ped-filter{display:flex;gap:.6rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1rem;background:rgba(255,255,255,.04);padding:.9rem;border-radius:10px;border:1px solid rgba(201,168,76,.1)}
        .ped-filter label{display:block;font-size:.72rem;color:#888;margin-bottom:.2rem}
        .ped-filter select,.ped-filter input{padding:.5rem .65rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.82rem}
        .ped-filter select option{background:#1a1010}
        .ped-filter input:focus,.ped-filter select:focus{outline:none;border-color:var(--ouro)}
        .btn-ped-refresh{padding:.5rem .9rem;background:rgba(201,168,76,.12);color:var(--ouro);border:1px solid rgba(201,168,76,.25);border-radius:6px;font-size:.82rem;font-weight:600;cursor:pointer}
        .ped-kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:.7rem;margin-bottom:1rem}
        .ped-grid{display:flex;flex-direction:column;gap:.65rem}
        .ped-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.1);border-radius:10px;padding:.9rem 1rem;display:grid;grid-template-columns:1fr auto;gap:.6rem;align-items:start}
        .ped-card.pago{border-color:rgba(46,125,50,.25);background:rgba(46,125,50,.04)}
        .ped-status{display:inline-block;padding:.2rem .65rem;border-radius:12px;font-size:.7rem;font-weight:700;letter-spacing:.4px}
        .ps-aberto{background:rgba(230,81,0,.2);color:#FFA726;border:1px solid rgba(230,81,0,.25)}
        .ps-pago{background:rgba(46,125,50,.2);color:#66BB6A;border:1px solid rgba(46,125,50,.25)}
        .ped-card-top{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.3rem}
        .ped-vendedor{font-size:.75rem;background:rgba(122,40,50,.3);color:var(--ouro-lt);padding:.15rem .55rem;border-radius:8px}
        .ped-meta{font-size:.78rem;color:#9e8e8e;margin-bottom:.3rem}
        .ped-cliente{font-size:.85rem;color:var(--creme);font-weight:500}
        .ped-itens{font-size:.78rem;color:#c5b5b5;margin-top:.35rem;line-height:1.55}
        .ped-card-right{display:flex;flex-direction:column;align-items:flex-end;gap:.5rem}
        .ped-total{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;color:var(--ouro)}
        .btn-pagar{padding:.45rem .85rem;background:linear-gradient(135deg,var(--ok),#1B5E20);color:#fff;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:700;cursor:pointer;white-space:nowrap}
        .btn-reabrir{padding:.45rem .85rem;background:rgba(230,81,0,.15);color:#FFA726;border:1px solid rgba(230,81,0,.25);border-radius:8px;font-size:.78rem;font-weight:600;cursor:pointer;white-space:nowrap}
        .btn-editar-ped{padding:.45rem .75rem;background:rgba(201,168,76,.1);color:var(--ouro);border:1px solid rgba(201,168,76,.25);border-radius:8px;font-size:.78rem;font-weight:600;cursor:pointer;white-space:nowrap}
        .btn-excluir-ped{padding:.45rem .65rem;background:rgba(198,40,40,.12);color:#EF5350;border:1px solid rgba(198,40,40,.25);border-radius:8px;font-size:.78rem;font-weight:600;cursor:pointer}
        .ped-card-actions{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem}
        .ped-empty{text-align:center;padding:2rem;color:#6b5b5b}
        /* histórico */
        .order-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.1);border-radius:10px;padding:.9rem;margin-bottom:.7rem}
        .order-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.55rem;flex-wrap:wrap;gap:.4rem}
        .order-meta{font-size:.78rem;color:#9e8e8e;margin-top:.15rem}
        .order-total-badge{background:rgba(201,168,76,.12);color:var(--ouro);padding:.2rem .65rem;border-radius:20px;font-size:.82rem;font-weight:600;white-space:nowrap}
        .order-items{font-size:.82rem;color:#c5b5b5;line-height:1.65}
        .order-vendedor{display:inline-block;background:rgba(122,40,50,.35);color:var(--ouro-lt);padding:.15rem .55rem;border-radius:8px;font-size:.72rem;margin-bottom:.3rem}
        .empty-orders{text-align:center;padding:2.5rem;color:#6b5b5b}
        /* editar pedido — inline dentro do admin */
        .edit-ped-inline{background:rgba(255,255,255,.04);border:1.5px solid var(--ouro);border-radius:12px;padding:1.1rem;margin-top:.5rem;display:none}
        .edit-ped-inline.open{display:block;animation:fadeIn .2s}
        .ep-fld label{display:block;font-size:.72rem;color:#9e8e8e;margin-bottom:.25rem;text-transform:uppercase;letter-spacing:.4px}
        .ep-fld input,.ep-fld select{width:100%;padding:.6rem .8rem;border:1.5px solid rgba(122,40,50,.45);border-radius:8px;background:rgba(255,255,255,.06);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.88rem}
        .ep-fld input:focus,.ep-fld select:focus{outline:none;border-color:var(--ouro)}
        .ep-fld select option{background:#1a1010}
        .ep-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem}
        @media(max-width:520px){.ep-row{grid-template-columns:1fr}}
        .ep-itens-list{display:flex;flex-direction:column;gap:.45rem;margin-bottom:.5rem}
        .ep-item-row{display:grid;grid-template-columns:1fr 55px 85px 30px;gap:.35rem;align-items:center}
        .ep-item-row input{padding:.42rem .55rem;border:1px solid rgba(122,40,50,.4);border-radius:6px;background:rgba(255,255,255,.05);color:var(--creme);font-family:'DM Sans',sans-serif;font-size:.8rem}
        .ep-item-row input:focus{outline:none;border-color:var(--ouro)}
        .btn-ep-del-item{width:26px;height:26px;background:rgba(198,40,40,.15);border:1px solid rgba(198,40,40,.25);color:#EF5350;border-radius:5px;cursor:pointer;font-size:.85rem;display:flex;align-items:center;justify-content:center}
        .btn-ep-add-item{padding:.4rem .85rem;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);color:var(--ouro);border-radius:6px;font-size:.78rem;font-weight:600;cursor:pointer;margin-top:.2rem}
        .btn-ep-save{padding:.65rem 1.2rem;background:var(--ok);color:#fff;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.85rem;cursor:pointer}
        .btn-ep-cancel{padding:.65rem 1rem;background:transparent;border:1px solid rgba(201,168,76,.2);color:var(--ouro-lt);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.85rem;cursor:pointer}
        .ep-total-display{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--ouro);margin-top:.25rem}


        /* ══ BLOQUEIO MENSAL ══ */
        #lockScreen{display:none;position:fixed;inset:0;background:linear-gradient(160deg,#1a1010 0%,#2d1010 100%);z-index:99999;align-items:center;justify-content:center;padding:1rem}
        #lockScreen.show{display:flex}
        .lock-box{background:#1a1010;border:2px solid #7A2832;border-radius:20px;padding:2.5rem;max-width:440px;width:100%;text-align:center}
        .lock-icon{font-size:3.5rem;margin-bottom:1rem}
        .lock-title{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--ouro-lt);margin-bottom:.5rem}
        .lock-sub{font-size:.9rem;color:#9e8e8e;line-height:1.6;margin-bottom:1.5rem}
        .lock-input{width:100%;max-width:280px;padding:.85rem 1rem;border-radius:10px;border:1.5px solid rgba(201,168,76,.3);background:rgba(255,255,255,.05);color:var(--creme);font-size:1rem;text-align:center;letter-spacing:6px;margin-bottom:.8rem;display:block;margin:0 auto .8rem}
        .lock-input:focus{outline:none;border-color:var(--ouro)}
        .btn-unlock{padding:.8rem 2rem;background:linear-gradient(135deg,var(--vinho),var(--vinho-dk));color:var(--ouro-lt);border:1px solid var(--ouro);border-radius:10px;font-size:1rem;font-weight:600;cursor:pointer;width:100%}
        .lock-error{color:#EF5350;font-size:.85rem;margin-top:.5rem;min-height:1.2rem}
        .lock-contact{margin-top:1.2rem;font-size:.8rem;color:#6b5b5b}

        @media print{body>*:not(.catalog-overlay){display:none !important}.catalog-overlay{position:static !important;background:none !important;padding:0 !important;display:block !important}.catalog-toolbar,.label-card-footer{display:none !important}.catalog-grid{grid-template-columns:repeat(4,1fr) !important}}
        @media(max-width:640px){.cart-fab{top:auto;bottom:5rem;right:1.5rem}}
    </style>
</head>
<body>


<!-- TELA DE BLOQUEIO MENSAL -->
<div id="lockScreen">
    <div class="lock-box">
        <div class="lock-icon">🔒</div>
        <div class="lock-title">Acesso Bloqueado</div>
        <div class="lock-sub">
            Seu acesso ao <strong style="color:var(--ouro-lt)" id="lockProdNome"></strong> está temporariamente suspenso.<br>
            Para continuar usando, entre em contato e informe o código de renovação.
        </div>
        <input class="lock-input" type="password" id="unlockInput" placeholder="••••••••••" onkeyup="if(event.key==='Enter')tryUnlock()">
        <button class="btn-unlock" onclick="tryUnlock()">🔓 Desbloquear</button>
        <div class="lock-error" id="lockError"></div>
        <div class="lock-contact">Suporte: <span id="lockWpp"></span></div>
    </div>
</div>

<div id="loadingScreen">
    <div class="load-title">🍷 VinotecaBR</div>
    <div class="load-spinner"></div>
    <div class="load-status" id="loadStatus">Conectando ao banco de dados...</div>
</div>

<div id="configAlert">
    <div class="config-box">
        <h2>⚙️ Configure o Firebase primeiro</h2>
        <p>As credenciais ainda não foram preenchidas no arquivo. Siga os passos:</p>
        <ol>
            <li>Acesse <a href="https://console.firebase.google.com" target="_blank">console.firebase.google.com</a></li>
            <li>Clique em <strong>Adicionar projeto</strong> → dê um nome → crie</li>
            <li>Na tela do projeto, clique em <strong>Web (&lt;/&gt;)</strong> → registre o app</li>
            <li>Copie o bloco <code>firebaseConfig</code> que aparecer</li>
            <li>Cole os valores em <code>FIREBASE_CONFIG</code> no topo do <code>index.html</code></li>
            <li>No menu lateral: <strong>Build → Realtime Database → Criar banco</strong></li>
            <li>Na aba <strong>Regras</strong>, cole: <code>{"rules":{".read":true,".write":true}}</code></li>
            <li>Salve e reabra o site</li>
        </ol>
        <p style="font-size:.8rem;color:#888;margin-top:.5rem">Guia completo no arquivo <strong>FIREBASE_SETUP.md</strong></p>
    </div>
</div>

