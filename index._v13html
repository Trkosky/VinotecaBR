// ── MARGEM ──
function loadMargem(){
    const tbody = document.getElementById('margemTabela');
    const kpis  = document.getElementById('margemKpis');
    tbody.innerHTML = '';

    let totalCusto=0, totalVenda=0, totalEstoque=0;
    wines.forEach(w=>{
        const custo  = w.custo || 0;
        const venda  = w.price || 0;
        const margem = venda - custo;
        const pct    = custo > 0 ? (margem/custo*100) : 0;
        const custoTotal = custo * (w.stock||0);
        totalCusto   += custoTotal;
        totalVenda   += venda * (w.stock||0);
        totalEstoque += w.stock||0;

        const cls = pct >= 40 ? 'bm-ok' : pct >= 15 ? 'bm-warn' : 'bm-bad';
        const tr  = document.createElement('tr');
        tr.innerHTML = `<td>${w.name}</td>
            <td>R$ ${fmt(custo)}</td>
            <td>R$ ${fmt(venda)}</td>
            <td style="color:${margem>=0?'#66BB6A':'#EF5350'}">R$ ${fmt(margem)}</td>
            <td><span class="badge-margin ${cls}">${pct.toFixed(1)}%</span></td>
            <td>${w.stock||0} un</td>
            <td>R$ ${fmt(custoTotal)}</td>`;
        tbody.appendChild(tr);
    });

    const margemTotal = totalVenda - totalCusto;
    kpis.innerHTML = `
        <div class="kpi-card"><div class="kpi-label">Custo em Estoque</div><div class="kpi-value">R$ ${fmt(totalCusto)}</div></div>
        <div class="kpi-card"><div class="kpi-label">Valor de Venda em Estoque</div><div class="kpi-value">R$ ${fmt(totalVenda)}</div></div>
        <div class="kpi-card"><div class="kpi-label">Margem Bruta Estoque</div><div class="kpi-value ${margemTotal>=0?'pos':'neg'}">R$ ${fmt(margemTotal)}</div></div>
        <div class="kpi-card"><div class="kpi-label">Total de Unidades</div><div class="kpi-value">${totalEstoque}</div></div>`;
}

// ── DESPESAS ──
function loadDespesas(){
    const tbody = document.getElementById('despesasTabela');
    const kpis  = document.getElementById('despesasKpis');
    tbody.innerHTML = '<tr><td colspan="5" style="color:#9e8e8e;padding:1rem">Carregando...</td></tr>';

    db.ref('despesas').orderByChild('timestamp').once('value', snap=>{
        const data = snap.val();
        tbody.innerHTML = '';
        if(!data){
            tbody.innerHTML = '<tr><td colspan="5" style="color:#6b5b5b;text-align:center;padding:1.5rem">Nenhuma despesa lançada.</td></tr>';
            kpis.innerHTML  = '<div class="kpi-card"><div class="kpi-label">Total de Despesas</div><div class="kpi-value">R$ 0,00</div></div>';
            return;
        }
        const list  = Object.entries(data).sort((a,b)=>b[1].timestamp-a[1].timestamp);
        let   total = 0;
        const catTotals = {};
        list.forEach(([key, d])=>{
            total += d.valor;
            catTotals[d.categoria] = (catTotals[d.categoria]||0) + d.valor;
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${d.data}</td><td>${d.descricao}</td><td style="color:#9e8e8e">${d.categoria}</td>
                <td style="color:#EF5350">R$ ${fmt(d.valor)}</td>
                <td><button class="btn-del-desp" onclick="delDespesa('${key}')">🗑️</button></td>`;
            tbody.appendChild(tr);
        });

        // maior categoria
        const topCat = Object.entries(catTotals).sort((a,b)=>b[1]-a[1])[0];
        kpis.innerHTML = `
            <div class="kpi-card"><div class="kpi-label">Total de Despesas</div><div class="kpi-value neg">R$ ${fmt(total)}</div></div>
            <div class="kpi-card"><div class="kpi-label">Nº de Lançamentos</div><div class="kpi-value">${list.length}</div></div>
            ${topCat?`<div class="kpi-card"><div class="kpi-label">Maior Categoria</div><div class="kpi-value" style="font-size:1rem">${topCat[0]}<br><span style="color:#EF5350;font-size:1.3rem">R$ ${fmt(topCat[1])}</span></div></div>`:''}`;
    });
}

async function addDespesa(){
    const desc = document.getElementById('dDesc').value.trim();
    const val  = parseFloat(document.getElementById('dVal').value);
    const cat  = document.getElementById('dCat').value;
    const data = document.getElementById('dData').value;
    if(!desc || !val || !data){ toast('Preencha descrição, valor e data!','err'); return; }
    const key  = Date.now()+'_'+Math.random().toString(36).substr(2,4);
    await db.ref('despesas/'+key).set({ descricao:desc, valor:val, categoria:cat, data, timestamp:Date.now() });
    document.getElementById('dDesc').value = '';
    document.getElementById('dVal').value  = '';
    toast('Despesa lançada! ✅');
    loadDespesas();
}

async function delDespesa(key){
    if(!confirm('Remover esta despesa?')) return;
    await db.ref('despesas/'+key).remove();
    toast('Despesa removida.');
    loadDespesas();
}

// ── COMISSÕES ──
async function saveComPct(){
    await saveComConfig();
}
async function saveComConfig(){
    const pct = parseFloat(document.getElementById('comPctGlobal').value)||0;
    const imp = parseFloat(document.getElementById('comImpGlobal').value)||0;
    await db.ref('config').update({ comissao_pct: pct, imposto_pct: imp });
    toast('Configuração salva! ✅');
    loadComissoes();
}

function loadComissoes(){
    const de   = document.getElementById('comDe').value;
    const ate  = document.getElementById('comAte').value;
    const vend = document.getElementById('comVendedor').value;
    const pct  = parseFloat(document.getElementById('comPctGlobal').value)||0;
    const imp  = parseFloat(document.getElementById('comImpGlobal').value)||0;
    const cards = document.getElementById('comCards');
    const kpis  = document.getElementById('comKpis');
    cards.innerHTML = '<p style="color:#9e8e8e;padding:.5rem 0">Carregando...</p>';

    db.ref('orders').orderByChild('timestamp').once('value', snap=>{
        const data = snap.val();
        if(!data){ cards.innerHTML='<p style="color:#6b5b5b;text-align:center;padding:2rem">Nenhum pedido encontrado.</p>'; return; }

        const deTs  = de  ? new Date(de+'T00:00:00').getTime()  : 0;
        const ateTs = ate ? new Date(ate+'T23:59:59').getTime() : Infinity;

        const orders = Object.values(data).filter(o=>{
            const ts = o.timestamp||0;
            if(ts < deTs || ts > ateTs) return false;
            if(vend && o.vendedor !== vend) return false;
            return true;
        });

        // custo total do catálogo por produto (para descontar da comissão)
        const custoPorNome = {};
        wines.forEach(w=>{ custoPorNome[w.name] = w.custo||0; });

        // agrupa por vendedor incluindo custo dos itens
        const byVend = {};
        orders.forEach(o=>{
            if(!byVend[o.vendedor]) byVend[o.vendedor]={ total:0, pedidos:0, itens:0, custo:0, orders:[] };
            byVend[o.vendedor].total   += o.total||0;
            byVend[o.vendedor].pedidos += 1;
            byVend[o.vendedor].orders.push(o);
            (o.itens||[]).forEach(i=>{
                byVend[o.vendedor].itens += i.qty;
                byVend[o.vendedor].custo += (custoPorNome[i.nome]||0) * i.qty;
            });
        });

        const totalGeral  = Object.values(byVend).reduce((s,v)=>s+v.total,0);
        const impGeral    = totalGeral * imp/100;
        const custoGeral  = Object.values(byVend).reduce((s,v)=>s+v.custo,0);
        const baseGeral   = Math.max(0, totalGeral - impGeral - custoGeral);
        const comTotal    = baseGeral * pct/100;

        kpis.innerHTML = `
            <div class="kpi-card"><div class="kpi-label">Total Vendido</div><div class="kpi-value">R$ ${fmt(totalGeral)}</div></div>
            <div class="kpi-card"><div class="kpi-label">(-) Impostos ${imp}%</div><div class="kpi-value neg">R$ ${fmt(impGeral)}</div></div>
            <div class="kpi-card"><div class="kpi-label">(-) Custo de Compra</div><div class="kpi-value neg">R$ ${fmt(custoGeral)}</div></div>
            <div class="kpi-card"><div class="kpi-label">Base p/ Comissão</div><div class="kpi-value">R$ ${fmt(baseGeral)}</div></div>
            <div class="kpi-card"><div class="kpi-label">Total Comissões ${pct}%</div><div class="kpi-value green">R$ ${fmt(comTotal)}</div></div>`;

        cards.innerHTML = '';
        if(!Object.keys(byVend).length){
            cards.innerHTML='<p style="color:#6b5b5b;text-align:center;padding:2rem">Nenhuma venda no período.</p>';
            return;
        }

        Object.entries(byVend).sort((a,b)=>b[1].total-a[1].total).forEach(([nome, v])=>{
            const impV  = v.total * imp/100;
            const baseV = Math.max(0, v.total - impV - v.custo);
            const comV  = baseV * pct/100;
            const card  = document.createElement('div');
            card.className = 'com-vendor-card';
            card.innerHTML = `
                <div class="com-vendor-name">👤 ${nome}</div>
                <div class="com-vendor-stats">
                    <div class="com-stat"><div class="com-stat-lbl">Pedidos</div><div class="com-stat-val">${v.pedidos}</div></div>
                    <div class="com-stat"><div class="com-stat-lbl">Itens</div><div class="com-stat-val">${v.itens}</div></div>
                    <div class="com-stat"><div class="com-stat-lbl">Total Vendido</div><div class="com-stat-val gold">R$ ${fmt(v.total)}</div></div>
                    <div class="com-stat"><div class="com-stat-lbl">Base Líquida</div><div class="com-stat-val">R$ ${fmt(baseV)}</div></div>
                    <div class="com-stat"><div class="com-stat-lbl">Comissão (${pct}%)</div><div class="com-stat-val green">R$ ${fmt(comV)}</div></div>
                </div>
                <div style="margin-top:.8rem">
                    <button onclick="gerarPdfComissaoById('${_pdfStoreKey(nome,v.orders,de,ate,pct,imp)}')"
                        style="padding:.45rem 1rem;background:linear-gradient(135deg,#7A2832,#4A1820);color:var(--ouro-lt);border:1px solid var(--ouro);border-radius:8px;font-size:.8rem;font-weight:600;cursor:pointer">
                        📄 Gerar PDF
                    </button>
                </div>`;
            cards.appendChild(card);
        });
    });
}


// ── PDF store (avoids JSON-in-onclick quoting issues) ──
const _pdfStore = {};
function _pdfStoreKey(vendedor, orders, de, ate, pct, imp){
    const key = 'pdf_' + Date.now() + '_' + Math.random().toString(36).substr(2,4);
    _pdfStore[key] = {vendedor, orders, de, ate, pct, imp};
    return key;
}
function gerarPdfComissaoById(key){
    const d = _pdfStore[key];
    if(!d){ console.error('PDF data not found for key:', key); return; }
    gerarPdfComissao(d.vendedor, d.orders, d.de, d.ate, d.pct, d.imp);
}

// ── GERAR PDF DE COMISSÃO ──
function gerarPdfComissao(vendedor, orders, de, ate, pctCom, pctImp){
    const custoPorNome = {};
    wines.forEach(w=>{ custoPorNome[w.name] = w.custo||0; });

    let totalVenda=0, totalCusto=0;
    const linhas = [];
    orders.forEach(o=>{
        totalVenda += o.total||0;
        let custoOrder=0;
        (o.itens||[]).forEach(i=>{ custoOrder += (custoPorNome[i.nome]||0)*i.qty; });
        totalCusto += custoOrder;
        linhas.push({ data:o.data, hora:o.hora, cliente:o.cliente, total:o.total||0 });
    });

    const impValor  = totalVenda * pctImp/100;
    const baseLiq   = Math.max(0, totalVenda - impValor - totalCusto);
    const comValor  = baseLiq * pctCom/100;

    const periodoStr = de && ate ? `${de.split('-').reverse().join('/')} a ${ate.split('-').reverse().join('/')}` : 'Período completo';

    const html = `<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Relatório de Comissão — ${vendedor}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:wght@400;600&display=swap');
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'DM Sans',sans-serif;color:#222;background:#fff;padding:0}
  .page{max-width:700px;margin:0 auto;padding:40px 48px}
  .logo{font-family:'Cormorant Garamond',serif;font-size:2rem;color:#4A1820;letter-spacing:2px;margin-bottom:4px}
  .sub{font-size:.9rem;color:#888;font-style:italic;margin-bottom:32px}
  h2{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:#4A1820;margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid #C9A84C}
  .info-row{display:flex;justify-content:space-between;margin-bottom:24px;gap:16px;flex-wrap:wrap}
  .info-box{background:#fdf6ec;border:1px solid #e8d5a3;border-radius:8px;padding:12px 18px;flex:1;min-width:140px}
  .info-lbl{font-size:.72rem;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
  .info-val{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:#4A1820}
  table{width:100%;border-collapse:collapse;margin-bottom:32px;font-size:.85rem}
  th{text-align:left;padding:8px 10px;background:#4A1820;color:#E8D5A3;font-weight:500;font-size:.78rem;text-transform:uppercase;letter-spacing:.5px}
  td{padding:8px 10px;border-bottom:1px solid #f0e8d8;color:#444}
  tr:hover td{background:#fdf6ec}
  .resumo{background:#fdf6ec;border:2px solid #C9A84C;border-radius:10px;padding:20px 24px;margin-bottom:32px}
  .res-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #e8d5a3;font-size:.9rem;color:#555}
  .res-row:last-child{border:none;font-size:1.1rem;font-weight:600;color:#4A1820;padding-top:12px}
  .res-row span:last-child{font-family:'Cormorant Garamond',serif;font-size:1.1rem}
  .res-row.destaque span:last-child{color:#2E7D32;font-size:1.3rem}
  .footer{text-align:center;font-size:.78rem;color:#bbb;border-top:1px solid #e8d5a3;padding-top:16px}
  @media print{body{padding:0}.page{padding:24px 32px}}
</style>
</head>
<body>
<div class="page">
  <div class="logo">🍷 ${STORE_NAME}</div>
  <div class="sub">Relatório de Comissão</div>

  <div class="info-row">
    <div class="info-box"><div class="info-lbl">Vendedor</div><div class="info-val">${vendedor}</div></div>
    <div class="info-box"><div class="info-lbl">Período</div><div class="info-val" style="font-size:1rem">${periodoStr}</div></div>
    <div class="info-box"><div class="info-lbl">Total de Pedidos</div><div class="info-val">${orders.length}</div></div>
  </div>

  <h2>Pedidos do Período</h2>
  <table>
    <thead><tr><th>Data</th><th>Hora</th><th>Cliente</th><th style="text-align:right">Valor</th></tr></thead>
    <tbody>
      ${linhas.map(l=>`<tr><td>${l.data}</td><td>${l.hora}</td><td>${l.cliente}</td><td style="text-align:right">R$ ${fmt(l.total)}</td></tr>`).join('')}
    </tbody>
  </table>

  <h2>Resumo Financeiro</h2>
  <div class="resumo">
    <div class="res-row"><span>Total bruto de vendas</span><span>R$ ${fmt(totalVenda)}</span></div>
    <div class="res-row" style="color:#c62828"><span>(-) Descontos aplicados</span><span>R$ ${fmt(impValor + totalCusto)}</span></div>
    <div class="res-row"><span><strong>Base de cálculo</strong></span><span>R$ ${fmt(baseLiq)}</span></div>
    <div class="res-row destaque"><span>Comissão (${pctCom}% sobre base)</span><span>R$ ${fmt(comValor)}</span></div>
  </div>

  <div class="footer">${STORE_NAME} &nbsp;•&nbsp; Gerado em ${new Date().toLocaleDateString('pt-BR')} às ${new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})} &nbsp;•&nbsp; Documento interno</div>
</div>
<scr'+'ipt>window.onload=()=>window.print()<'+'/script>
</body>
</html>`;

    const blob = new Blob([html], {type:'text/html'});
    const url  = URL.createObjectURL(blob);
    window.open(url, '_blank');
}


// ══════════════════════════════════════════════════════
//  PEDIDOS EM ABERTO
// ══════════════════════════════════════════════════════



function loadPedidos(){
    const status = document.getElementById('pedStatus').value;
    const vend   = document.getElementById('pedVend').value;
    const de     = document.getElementById('pedDe').value;
    const ate    = document.getElementById('pedAte').value;
    const grid   = document.getElementById('pedGrid');
    const kpis   = document.getElementById('pedKpis');
    grid.innerHTML  = '<div class="ped-empty"><p>Carregando...</p></div>';
    kpis.innerHTML  = '';

    db.ref('orders').orderByChild('timestamp').once('value', snap=>{
        const raw = snap.val();
        if(!raw){ grid.innerHTML='<div class="ped-empty"><p>📋 Nenhum pedido encontrado.</p></div>'; return; }

        const deTs  = de  ? new Date(de +'T00:00:00').getTime() : 0;
        const ateTs = ate ? new Date(ate+'T23:59:59').getTime() : Infinity;

        // montamos com chave para poder dar baixa
        let entries = Object.entries(raw)
            .map(([key,o]) => ({key,...o}))
            .filter(o => {
                if(o.timestamp < deTs || o.timestamp > ateTs) return false;
                if(vend   && o.vendedor !== vend) return false;
                if(status && (o.status||'aberto') !== status) return false;
                return true;
            })
            .sort((a,b) => b.timestamp - a.timestamp);

        // KPIs
        const totAberto = entries.filter(o=>(o.status||'aberto')==='aberto').reduce((s,o)=>s+o.total,0);
        const totPago   = entries.filter(o=> o.status              ==='pago' ).reduce((s,o)=>s+o.total,0);
        const nAberto   = entries.filter(o=>(o.status||'aberto')==='aberto').length;
        const nPago     = entries.filter(o=> o.status              ==='pago' ).length;
        kpis.innerHTML  = `
            <div class="kpi-card"><div class="kpi-label">Em aberto (R$)</div><div class="kpi-value" style="color:#FFA726">R$ ${fmt(totAberto)}</div></div>
            <div class="kpi-card"><div class="kpi-label">Em aberto (qtd)</div><div class="kpi-value" style="color:#FFA726">${nAberto}</div></div>
            <div class="kpi-card"><div class="kpi-label">Pagos (R$)</div><div class="kpi-value pos">R$ ${fmt(totPago)}</div></div>
            <div class="kpi-card"><div class="kpi-label">Pagos (qtd)</div><div class="kpi-value pos">${nPago}</div></div>`;

        if(!entries.length){
            grid.innerHTML = '<div class="ped-empty"><p>Nenhum pedido para os filtros selecionados.</p></div>';
            return;
        }

        grid.innerHTML = '';
        entries.forEach(o => {
            const isPago = o.status === 'pago';
            const itensHtml = (o.itens||[]).map(i=>`${i.qty}x ${i.nome} — R$ ${fmt(i.preco)}`).join(' &nbsp;·&nbsp; ');
            const card = document.createElement('div');
            card.className = 'ped-card' + (isPago ? ' pago' : '');
            card.innerHTML = `
                <div class="ped-card-left">
                    <div class="ped-card-top">
                        <span class="ped-status ${isPago?'ps-pago':'ps-aberto'}">${isPago?'✓ PAGO':'● ABERTO'}</span>
                        <span class="ped-vendedor">👤 ${o.vendedor}</span>
                    </div>
                    <div class="ped-meta">${o.data} às ${o.hora}</div>
                    <div class="ped-cliente">👤 ${o.cliente} &nbsp;|&nbsp; 📱 ${o.telefone}${o.endereco?' &nbsp;|&nbsp; 📍 '+o.endereco:''}</div>
                    <div class="ped-itens">${itensHtml}</div>
                </div>
                <div class="ped-card-right">
                    <div class="ped-total">R$ ${fmt(o.total)}</div>
                    <div class="ped-card-actions">
                        ${isPago
                            ? `<button class="btn-reabrir" onclick="setPedStatus('${o.key}','aberto')">↩ Reabrir</button>`
                            : `<button class="btn-pagar"  onclick="setPedStatus('${o.key}','pago')">✓ Pago</button>`
                        }
                        <button class="btn-editar-ped"  onclick="openEditPed('${o.key}')">✏️ Editar</button>
                        <button class="btn-excluir-ped" onclick="confirmDelPed('${o.key}','${o.cliente}')">🗑️</button>
                    </div>
                </div>`;
            grid.appendChild(card);
        });
    });
}


// ══ EDITAR / EXCLUIR PEDIDO ══

let _editPedData = null; // guarda o pedido sendo editado















async function setPedStatus(key, novoStatus){
    await db.ref(`orders/${key}/status`).set(novoStatus);
    const msg = novoStatus === 'pago' ? '✅ Pedido marcado como PAGO!' : '↩ Pedido reaberto.';
    toast(msg, novoStatus==='pago'?'ok':'info');
    loadPedidos();
}


// ══ ADMIN UNIFICADO — NAVEGAÇÃO ══
const _sectionTitles = {
    vinhos:    '🍷 Gerenciar Vinhos',
    pedidos:   '🧾 Pedidos em Aberto',
    historico: '📋 Histórico de Pedidos',
    margem:    '📦 Margem por Vinho',
    despesas:  '💸 Despesas',
    comissoes: '🏆 Comissões',
};

function navAdmin(section){
    // Update nav buttons
    document.querySelectorAll('.adm-nav-btn').forEach(b=>b.classList.remove('active'));
    const btn = document.getElementById('nav-'+section);
    if(btn) btn.classList.add('active');

    // Update title
    document.getElementById('adminSectionTitle').textContent = _sectionTitles[section]||'';

    // Show section
    document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
    const sec = document.getElementById('sec-'+section);
    if(sec) sec.classList.add('active');

    // Load data for section
    if(section==='pedidos')   loadPedidos();
    if(section==='historico') loadOrders();
    if(section==='margem')    loadMargem();
    if(section==='despesas')  loadDespesas();
    if(section==='comissoes') loadComissoesInit();
}

function openAdmin(){
    document.getElementById('adminOverlay').classList.add('open');
}
function closeAdmin(){
    document.getElementById('adminOverlay').classList.remove('open');
}
function doLogin(){
    if(document.getElementById('adminPwd').value===ADMIN_PASSWORD){
        adminAuth=true;
        document.getElementById('loginBox').style.display='none';
        document.getElementById('adminContent').style.display='flex';
        // Init vendors in pedidos filter
        const sv = document.getElementById('pedVend');
        if(sv.options.length<=1){
            VENDEDORES.slice(1).forEach(v=>{
                const o=document.createElement('option');o.value=v;o.textContent=v;sv.appendChild(o);
            });
        }
        // Init dates
        const hoje = new Date().toISOString().split('T')[0];
        const ini  = new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
        document.getElementById('pedDe').value  = ini;
        document.getElementById('pedAte').value = hoje;
        document.getElementById('dData').value  = hoje;
        // Load config
        db.ref('config').once('value', s=>{
            const cfg=s.val()||{};
            if(cfg.comissao_pct) document.getElementById('comPctGlobal').value=cfg.comissao_pct;
            if(cfg.imposto_pct!==undefined) document.getElementById('comImpGlobal').value=cfg.imposto_pct;
        });
        navAdmin('vinhos');
        renderAdminList();
    } else toast('Senha incorreta!','err');
}

function loadOrders(){
    const body=document.getElementById('ordersBody');
    body.innerHTML='<p style="color:#9e8e8e;padding:1rem">Carregando...</p>';
    db.ref('orders').orderByChild('timestamp').limitToLast(100).once('value',snap=>{
        const data=snap.val();
        if(!data){body.innerHTML='<div class="empty-orders"><p>📋 Nenhum pedido ainda.</p></div>';return;}
        const orders=Object.values(data).sort((a,b)=>b.timestamp-a.timestamp);
        body.innerHTML='';
        orders.forEach(o=>{
            const card=document.createElement('div');card.className='order-card';
            const itens=(o.itens||[]).map(i=>`• ${i.nome} — ${i.qty}x R$${fmt(i.preco)}`).join('<br>');
            card.innerHTML=`<div class="order-header">
                <div><span class="order-vendedor">👤 ${o.vendedor}</span>
                <div class="order-meta">${o.data} às ${o.hora} &nbsp;|&nbsp; ${o.cliente} &nbsp;|&nbsp; ${o.telefone}${o.endereco?' &nbsp;|&nbsp; '+o.endereco:''}</div></div>
                <span class="order-total-badge">R$ ${fmt(o.total)}</span>
            </div><div class="order-items">${itens}</div>`;
            body.appendChild(card);
        });
    });
}

function loadComissoesInit(){
    // Populate vendor select if empty
    const sv=document.getElementById('comVendedor');
    if(sv.options.length<=1){
        VENDEDORES.slice(1).forEach(v=>{
            const o=document.createElement('option');o.value=v;o.textContent=v;sv.appendChild(o);
        });
    }
    const hoje=new Date().toISOString().split('T')[0];
    const ini=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
    if(!document.getElementById('comDe').value) document.getElementById('comDe').value=ini;
    if(!document.getElementById('comAte').value) document.getElementById('comAte').value=hoje;
}

// ── Edit pedido inline ──
function openEditPed(key){
    db.ref('orders/'+key).once('value', snap=>{
        const o=snap.val(); if(!o){toast('Pedido não encontrado','err');return;}
        const sv=document.getElementById('epVendedor');
        sv.innerHTML='';
        VENDEDORES.slice(1).forEach(v=>{
            const opt=document.createElement('option');opt.value=v;opt.textContent=v;
            if(v===o.vendedor)opt.selected=true;sv.appendChild(opt);
        });
        document.getElementById('epKey').value      =key;
        document.getElementById('epCliente').value  =o.cliente||'';
        document.getElementById('epTelefone').value =o.telefone||'';
        document.getElementById('epEndereco').value =o.endereco||'';
        document.getElementById('epStatus').value   =o.status||'aberto';
        const list=document.getElementById('epItensList');
        list.innerHTML='';
        (o.itens||[]).forEach(item=>epAddItemRow(item.nome,item.qty,item.preco));
        epCalcTotal();
        const el=document.getElementById('editPedInline');
        el.classList.add('open');
        el.scrollIntoView({behavior:'smooth',block:'nearest'});
    });
}
function closeEditPed(){
    document.getElementById('editPedInline').classList.remove('open');
}
function epAddItemRow(nome='',qty=1,preco=0){
    const list=document.getElementById('epItensList');
    const row=document.createElement('div');row.className='ep-item-row';
    row.innerHTML=`<input type="text" class="ep-nome" value="${nome}" placeholder="Produto" oninput="epCalcTotal()">
        <input type="number" class="ep-qty" value="${qty}" min="1" step="1" oninput="epCalcTotal()">
        <input type="number" class="ep-preco" value="${preco}" min="0" step="0.01" oninput="epCalcTotal()">
        <button class="btn-ep-del-item" onclick="this.parentElement.remove();epCalcTotal()" title="Remover">✕</button>`;
    list.appendChild(row);
}
function epAddItem(){epAddItemRow('',1,0);}
function epCalcTotal(){
    let total=0;
    document.querySelectorAll('#epItensList .ep-item-row').forEach(row=>{
        total+=(parseFloat(row.querySelector('.ep-qty').value)||0)*(parseFloat(row.querySelector('.ep-preco').value)||0);
    });
    document.getElementById('epTotalDisplay').textContent='R$ '+fmt(total);
    return total;
}
async function saveEditPed(){
    const key=document.getElementById('epKey').value;
    const vendedor=document.getElementById('epVendedor').value;
    const cliente=document.getElementById('epCliente').value.trim();
    const telefone=document.getElementById('epTelefone').value.trim();
    const endereco=document.getElementById('epEndereco').value.trim();
    const status=document.getElementById('epStatus').value;
    if(!cliente||!telefone){toast('Preencha cliente e telefone!','err');return;}
    const itens=[];
    document.querySelectorAll('#epItensList .ep-item-row').forEach(row=>{
        const nome=row.querySelector('.ep-nome').value.trim();
        const qty=parseFloat(row.querySelector('.ep-qty').value)||0;
        const preco=parseFloat(row.querySelector('.ep-preco').value)||0;
        if(nome&&qty>0)itens.push({nome,qty,preco});
    });
    if(!itens.length){toast('Adicione pelo menos um item!','err');return;}
    const total=itens.reduce((s,i)=>s+i.qty*i.preco,0);
    try{
        await db.ref('orders/'+key).update({vendedor,cliente,telefone,endereco,status,itens,total});
        toast('✅ Pedido atualizado!');
        closeEditPed();
        loadPedidos();
    }catch(e){toast('Erro: '+e.message,'err');}
}
async function confirmDelPed(key,cliente){
    if(!confirm('Excluir o pedido de "'+cliente+'"?\nEsta ação não pode ser desfeita.'))return;
    try{
        await db.ref('orders/'+key).remove();
        toast('Pedido excluído.','info');
        loadPedidos();
    }catch(e){toast('Erro: '+e.message,'err');}
}

function fmt(n){return n.toFixed(2).replace('.',',');}
function toast(msg,type='ok'){const el=document.getElementById('toast');el.textContent=msg;el.className=`toast show ${type}`;clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),3500);}

initFirebase();

</script>
</body>
</html>
