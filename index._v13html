<script>
let db=null, wines=[], cart=[], filter='todos', adminAuth=false, nextId=1;
let labelDataUrl='', labelWineName='';

document.getElementById('storeTitle').textContent = STORE_NAME;
document.getElementById('catTitle').textContent   = STORE_NAME;

const selVend = document.getElementById('selVendedor');
VENDEDORES.forEach(v=>{
    const o=document.createElement('option');
    o.value=v===VENDEDORES[0]?'':v; o.textContent=v;
    if(v===VENDEDORES[0]){o.disabled=true;o.selected=true;}
    selVend.appendChild(o);
});


// ══ ADMIN MENU HELPERS ══







// ══ BLOQUEIO MENSAL ══
function checkMonthlyLock(){
    const hoje = new Date();
    const dia  = hoje.getDate();
    const mes  = hoje.getMonth();  // 0-11
    const ano  = hoje.getFullYear();

    // Chave de desbloqueio salva no localStorage: "unlocked_MM_YYYY"
    const lockKey    = `unlocked_${mes}_${ano}`;
    const unlocked   = localStorage.getItem(lockKey);
    const unlockedAll= localStorage.getItem('unlocked_permanent');

    if(unlocked === 'true' || unlockedAll === 'true') return false; // liberado
    if(dia < LOCK_DAY) return false; // ainda dentro do prazo do mês

    return true; // deve bloquear
}

function showLock(){
    document.getElementById('lockProdNome').textContent = PRODUTO_NOME;
    document.getElementById('lockWpp').textContent = WHATSAPP_NUMBER;
    document.getElementById('lockScreen').classList.add('show');
}

function tryUnlock(){
    const input = document.getElementById('unlockInput').value.trim();
    const err   = document.getElementById('lockError');

    if(input === UNLOCK_CODE){
        // Salva liberação para o mês corrente
        const hoje   = new Date();
        const lockKey= `unlocked_${hoje.getMonth()}_${hoje.getFullYear()}`;
        localStorage.setItem(lockKey, 'true');
        document.getElementById('lockScreen').classList.remove('show');
        err.textContent = '';
        toast('✅ Sistema desbloqueado! Bom trabalho.');
    } else {
        err.textContent = 'Código incorreto. Entre em contato para renovar.';
        document.getElementById('unlockInput').value = '';
    }
}

// ══ FIREBASE INIT ══
function configOk(){ return FIREBASE_CONFIG.apiKey && FIREBASE_CONFIG.apiKey!=='COLE_AQUI'; }

async function initFirebase(){
    setLS('Verificando configuração...');
    if(checkMonthlyLock()){ showLock(); document.getElementById('loadingScreen').style.display='none'; return; }
    if(!configOk()){
        document.getElementById('loadingScreen').style.display='none';
        document.getElementById('configAlert').classList.add('show');
        return;
    }
    try{
        setLS('Conectando ao Firebase...');
        firebase.initializeApp(FIREBASE_CONFIG);
        db=firebase.database();

        // Autenticação anônima — protege contra acesso externo sem app
        setLS('Autenticando...');
        await firebase.auth().signInAnonymously();

        // Escuta vinhos em tempo real
        db.ref('wines').on('value', snap=>{
            const data=snap.val();
            if(data){
                wines=Object.values(data).sort((a,b)=>a.id-b.id);
                nextId=Math.max(...wines.map(w=>w.id))+1;
                renderWines();
            } else {
                setLS('Populando catálogo inicial...');
                const u={};
                WINES_INICIAL.forEach(w=>{ u[`wines/${w.id}`]=w; });
                db.ref().update(u).then(()=>toast('Catálogo carregado! ✅'));
            }
        });

        // Status de conexão
        db.ref('.info/connected').on('value', snap=>{
            const on=snap.val()===true;
            const el=document.getElementById('dbBadge');
            el.className=`db-badge ${on?'on':'off'}`;
            el.innerHTML=`<span class="db-dot"></span>${on?'online':'offline'}`;
        });

        setLS('Pronto!');
        setTimeout(()=>document.getElementById('loadingScreen').style.display='none', 500);
    }catch(e){
        setLS('Erro: '+e.message);
        setTimeout(()=>{
            document.getElementById('loadingScreen').style.display='none';
            toast('Erro ao conectar. Verifique FIREBASE_CONFIG.','err');
        },2500);
    }
}
function setLS(m){ document.getElementById('loadStatus').textContent=m; }

// ══ RENDER ══
function renderWines(){
    const grid=document.getElementById('wineGrid');
    const q=document.getElementById('searchInput').value.toLowerCase();
    grid.innerHTML='';
    const list=wines.filter(w=>{
        if(filter!=='todos'&&w.type!==filter)return false;
        if(q&&!w.name.toLowerCase().includes(q)&&!w.origin.toLowerCase().includes(q))return false;
        return true;
    });
    if(!list.length){grid.innerHTML='<p style="color:#6b5b5b;grid-column:1/-1;text-align:center;padding:3rem">Nenhum vinho encontrado.</p>';return;}
    list.forEach(w=>{
        const sc=w.stock>10?'s-ok':w.stock>5?'s-med':'s-low';
        const st=w.stock===0?'Esgotado':`${w.stock} unid.`;
        const imgH=w.image?`<img src="${w.image}" alt="${w.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`: '';
        const noH=`<div class="no-img" style="${w.image?'display:none':''}"><span class="no-img-icon">🍷</span><span>Sem imagem</span></div>`;
        const card=document.createElement('div'); card.className='wine-card';
        card.innerHTML=`
            <div class="wine-img-wrap">${imgH}${noH}
                <span class="type-badge type-${w.type}">${w.type}</span>
                <button class="btn-share-label" onclick="openLabelPreview(${w.id})" title="Enviar rótulo">📲</button>
            </div>
            <div class="wine-body">
                <div class="wine-name">${w.name}</div>
                <div class="wine-meta">📍 ${w.origin}&nbsp;&nbsp;|&nbsp;&nbsp;🗓️ ${w.year||'-'}</div>
                <div class="wine-desc">${w.description}</div>
                <div class="wine-footer">
                    <div class="price">R$ ${fmt(w.price)}</div>
                    <div class="stock-info"><div class="stock-label">Estoque</div><div class="stock-val ${sc}">${st}</div></div>
                </div>
                ${w.stock>0?`
                    <div class="qty-row">
                        <button class="qty-btn" onclick="changeQty(${w.id},-1)">−</button>
                        <span class="qty-val" id="qty-${w.id}">1</span>
                        <button class="qty-btn" onclick="changeQty(${w.id},1)">+</button>
                    </div>
                    <button class="btn-add" onclick="addCart(${w.id})">🛒 Adicionar ao Pedido</button>
                `:`<button class="btn-add" disabled>🚫 Esgotado</button>`}
            </div>`;
        grid.appendChild(card);
    });
}
function setFilter(btn){ document.querySelectorAll('.btn-filter').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); filter=btn.dataset.f; renderWines(); }
function changeQty(id,d){ const el=document.getElementById(`qty-${id}`); const max=wines.find(w=>w.id===id).stock; el.textContent=Math.min(max,Math.max(1,+el.textContent+d)); }

// ══ CARRINHO ══
function addCart(id){
    const wine=wines.find(w=>w.id===id); const qty=+document.getElementById(`qty-${id}`).textContent;
    const ex=cart.find(c=>c.id===id);
    if(ex){if(ex.qty+qty>wine.stock){toast('Quantidade máxima!','err');return;}ex.qty+=qty;}
    else cart.push({id,name:wine.name,price:wine.price,qty,image:wine.image});
    document.getElementById(`qty-${id}`).textContent='1';
    updateBadge(); toast('Adicionado! 🍷');
}
function updateBadge(){ document.getElementById('cartBadge').textContent=cart.reduce((s,c)=>s+c.qty,0); }
function openCart(){ renderCart(); document.getElementById('cartOverlay').classList.add('open'); }
function closeCart(){ document.getElementById('cartOverlay').classList.remove('open'); }
function renderCart(){
    const list=document.getElementById('cartList');
    if(!cart.length){list.innerHTML='<div class="empty-msg"><div>🍷</div><p>Carrinho vazio</p></div>';document.getElementById('cartTotal').textContent='R$ 0,00';return;}
    let total=0; list.innerHTML='';
    cart.forEach((item,i)=>{const sub=item.price*item.qty;total+=sub;
        const el=document.createElement('div');el.className='cart-item';
        el.innerHTML=`<img class="ci-img" src="${item.image||''}" alt="${item.name}" onerror="this.style.background='#2a1a1a';this.removeAttribute('src')">
            <div class="ci-info"><div class="ci-name">${item.name}</div><div class="ci-price">R$ ${fmt(item.price)} / un</div>
            <div class="ci-row"><button class="ci-qbtn" onclick="adjCart(${i},-1)">−</button><span>${item.qty}</span><button class="ci-qbtn" onclick="adjCart(${i},1)">+</button><span class="ci-subtotal">R$ ${fmt(sub)}</span></div></div>
            <span class="ci-del" onclick="delCart(${i})">🗑️</span>`;
        list.appendChild(el);
    });
    document.getElementById('cartTotal').textContent=`R$ ${fmt(total)}`;
}
function adjCart(i,d){const nq=cart[i].qty+d;const wine=wines.find(w=>w.id===cart[i].id);if(nq<1){delCart(i);return;}if(nq>wine.stock){toast('Limite!','err');return;}cart[i].qty=nq;renderCart();updateBadge();}
function delCart(i){cart.splice(i,1);renderCart();updateBadge();}

// ══ ENVIAR PEDIDO + BAIXA NO FIREBASE ══
async function sendWhatsApp(){
    const vendedor=document.getElementById('selVendedor').value;
    const name=document.getElementById('custName').value.trim();
    const phone=document.getElementById('custPhone').value.trim();
    const addr=document.getElementById('custAddr').value.trim();
    if(!vendedor){toast('Selecione o vendedor!','err');return;}
    if(!name||!phone){toast('Preencha nome e telefone!','err');return;}
    if(!cart.length){toast('Carrinho vazio!','err');return;}

    const btn=document.getElementById('btnEnviar');
    btn.disabled=true; btn.textContent='⏳ Salvando no banco...';

    const now=new Date();
    const data=now.toLocaleDateString('pt-BR');
    const hora=now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});

    let msg=`*PEDIDO - ${STORE_NAME}*\n`;
    msg+=`Data: ${data} as ${hora}\n─────────────────────\n`;
    msg+=`VENDEDOR: ${vendedor}\nCLIENTE: ${name}\nCONTATO: ${phone}\n`;
    if(addr) msg+=`LOCAL: ${addr}\n`;
    msg+=`─────────────────────\nITENS:\n\n`;
    let total=0;
    cart.forEach((c,i)=>{const sub=c.price*c.qty;total+=sub;
        msg+=`${i+1}. ${c.name}\n   ${c.qty} un x R$${fmt(c.price)} = R$${fmt(sub)}\n`;
    });
    msg+=`\n─────────────────────\nTOTAL: R$ ${fmt(total)}\n─────────────────────\nAguardo confirmacao!`;

    try{
        const updates={};
        // Baixa estoque no Firebase
        cart.forEach(c=>{
            const wine=wines.find(w=>w.id===c.id);
            if(wine) updates[`wines/${c.id}/stock`]=Math.max(0,wine.stock-c.qty);
        });
        // Salva pedido no histórico
        const key=`${Date.now()}_${Math.random().toString(36).substr(2,4)}`;
        updates[`orders/${key}`]={
            vendedor, cliente:name, telefone:phone,
            endereco:addr||'', data, hora, total, timestamp:Date.now(),
            status:'aberto',
            itens:cart.map(c=>({nome:c.name,qty:c.qty,preco:c.price}))
        };
        await db.ref().update(updates);

        window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`,'_blank');
        cart=[];
        updateBadge();
        closeCart();
        toast('✅ Pedido enviado! Estoque atualizado em tempo real.');
    }catch(e){
        toast('Erro: '+e.message,'err');
    }finally{
        btn.disabled=false;
        btn.innerHTML='📲 Enviar Pedido pelo WhatsApp';
    }
}

// ══ GERADOR DE RÓTULO ══
function loadImg(src){return new Promise((res,rej)=>{if(!src){rej();return;}const img=new Image();img.crossOrigin='anonymous';img.onload=()=>res(img);img.onerror=rej;img.src=src;});}
function roundRect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();}
function wrapText(ctx,text,x,y,maxW,lh){const words=text.split(' ');let line='';let cy=y;for(let n=0;n<words.length;n++){const test=line+words[n]+' ';if(ctx.measureText(test).width>maxW&&n>0){ctx.fillText(line.trim(),x,cy);line=words[n]+' ';cy+=lh;}else line=test;}ctx.fillText(line.trim(),x,cy);return cy;}
async function generateLabelCanvas(wine){
    const W=800,H=1080;const canvas=document.createElement('canvas');canvas.width=W;canvas.height=H;const ctx=canvas.getContext('2d');
    ctx.fillStyle='#FDF6EC';ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='#C9A84C';ctx.lineWidth=6;ctx.strokeRect(3,3,W-6,H-6);ctx.lineWidth=1.5;ctx.strokeRect(14,14,W-28,H-28);
    ctx.fillStyle='#4A1820';ctx.fillRect(3,3,W-6,120);
    ctx.fillStyle='#E8D5A3';ctx.font='bold 40px Georgia, serif';ctx.textAlign='center';ctx.fillText(STORE_NAME,W/2,78);
    const imgX=20,imgY=135,imgW=W-40,imgH=490;ctx.fillStyle='#f0e8d8';ctx.fillRect(imgX,imgY,imgW,imgH);
    try{const img=await loadImg(wine.image);const scale=Math.min(imgW/img.width,imgH/img.height);const sw=img.width*scale,sh=img.height*scale;ctx.drawImage(img,imgX+(imgW-sw)/2,imgY+(imgH-sh)/2,sw,sh);}
    catch(e){ctx.fillStyle='rgba(201,168,76,.25)';ctx.fillRect(imgX,imgY,imgW,imgH);ctx.fillStyle='#C9A84C';ctx.font='100px serif';ctx.textAlign='center';ctx.fillText('🍷',W/2,imgY+imgH/2+35);}
    ctx.strokeStyle='#C9A84C';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(30,640);ctx.lineTo(W-30,640);ctx.stroke();
    const tc={tinto:{bg:'#6B0000',fg:'#ffcccc'},branco:{bg:'#e8e8c8',fg:'#444'},rose:{bg:'#e8a4b8',fg:'#6B0030'},espumante:{bg:'#C9A84C',fg:'#2a1a00'}}[wine.type]||{bg:'#888',fg:'#fff'};
    ctx.font='bold 20px DM Sans, sans-serif';ctx.textAlign='left';const tw=ctx.measureText(wine.type.toUpperCase()).width+28;
    roundRect(ctx,30,654,tw,34,8);ctx.fillStyle=tc.bg;ctx.fill();ctx.fillStyle=tc.fg;ctx.fillText(wine.type.toUpperCase(),44,677);
    ctx.font='20px DM Sans, sans-serif';ctx.fillStyle='#999';ctx.textAlign='right';ctx.fillText(wine.year||'',W-30,677);
    ctx.fillStyle='#4A1820';ctx.font='bold 44px Georgia, serif';ctx.textAlign='center';
    const nameY=wrapText(ctx,wine.name,W/2,730,W-80,52);
    ctx.fillStyle='#888';ctx.font='22px DM Sans, sans-serif';ctx.fillText(`📍 ${wine.origin}`,W/2,nameY+46);
    ctx.fillStyle='#666';ctx.font='19px DM Sans, sans-serif';wrapText(ctx,wine.description,W/2,nameY+88,W-100,28);
    ctx.setLineDash([6,5]);ctx.strokeStyle='rgba(201,168,76,.5)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(30,940);ctx.lineTo(W-30,940);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='#C9A84C';ctx.font='bold 64px Georgia, serif';ctx.textAlign='center';ctx.fillText(`R$ ${fmt(wine.price)}`,W/2,1010);
    ctx.fillStyle='#4A1820';ctx.fillRect(3,H-70,W-6,67);ctx.fillStyle='#E8D5A3';ctx.font='18px DM Sans, sans-serif';ctx.textAlign='center';ctx.fillText('Entre em contato para fazer seu pedido',W/2,H-38);
    ctx.fillStyle='rgba(201,168,76,.6)';ctx.font='16px DM Sans, sans-serif';ctx.fillText(`WhatsApp: ${WHATSAPP_NUMBER}`,W/2,H-16);
    return canvas.toDataURL('image/jpeg',0.92);
}
async function openLabelPreview(id){
    const wine=wines.find(w=>w.id===id);labelWineName=wine.name;
    const ov=document.getElementById('labelPreviewOverlay'),img=document.getElementById('labelPreviewImg'),gm=document.getElementById('generatingMsg');
    img.style.display='none';document.getElementById('btnShareWpp').style.display='none';document.getElementById('btnDownload').style.display='none';
    gm.classList.add('show');ov.classList.add('open');
    try{labelDataUrl=await generateLabelCanvas(wine);img.src=labelDataUrl;img.style.display='block';document.getElementById('btnShareWpp').style.display='flex';document.getElementById('btnDownload').style.display='flex';}
    catch(e){toast('Erro ao gerar rótulo','err');ov.classList.remove('open');}
    finally{gm.classList.remove('show');}
}
function closePreview(){document.getElementById('labelPreviewOverlay').classList.remove('open');}
async function doShareWpp(){
    if(!labelDataUrl)return;const fname=labelWineName.replace(/[^a-zA-Z0-9]/g,'_')+'.jpg';
    try{const res=await fetch(labelDataUrl);const blob=await res.blob();const file=new File([blob],fname,{type:'image/jpeg'});
        if(navigator.share&&navigator.canShare&&navigator.canShare({files:[file]})){await navigator.share({files:[file],title:labelWineName});toast('Compartilhado!');return;}}catch(e){}
    doDownload();const msg=`🍷 *${labelWineName}*\n\n_Rótulo em anexo_\n\nInteressado? Entre em contato!`;
    setTimeout(()=>window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`,'_blank'),600);toast('Imagem salva! Anexe no WhatsApp. 📎','info');
}
function doDownload(){if(!labelDataUrl)return;const a=document.createElement('a');a.href=labelDataUrl;a.download=labelWineName.replace(/[^a-zA-Z0-9]/g,'_')+'.jpg';a.click();toast('Imagem baixada! ⬇️');}

// ══ CATÁLOGO ══
function openCatalog(){
    const now=new Date().toLocaleDateString('pt-BR',{year:'numeric',month:'long',day:'numeric'});
    document.getElementById('catHeaderTitle').textContent=STORE_NAME;
    document.getElementById('catHeaderDate').textContent=`Catálogo gerado em ${now}`;
    document.getElementById('catFooter').textContent=`${STORE_NAME} • ${wines.filter(w=>w.stock>0).length} produtos disponíveis`;
    const grid=document.getElementById('catalogGrid');grid.innerHTML='';
    wines.forEach(w=>{
        const sc=w.stock>10?'lsb-ok':w.stock>5?'lsb-med':'lsb-low';const st=w.stock===0?'Esgotado':`${w.stock} em estoque`;
        const imgH=w.image?`<img class="label-img" src="${w.image}" alt="${w.name}" onerror="this.outerHTML='<div class=\\'label-img-placeholder\\'>🍷</div>'">`:`<div class="label-img-placeholder">🍷</div>`;
        const card=document.createElement('div');card.className='label-card';
        card.innerHTML=`${imgH}<div class="label-body">
            <div class="label-type-row"><span class="label-badge lb-${w.type}">${w.type}</span><span class="label-year">${w.year||'-'}</span></div>
            <div class="label-name">${w.name}</div><div class="label-origin">📍 ${w.origin}</div>
            <div class="label-desc">${w.description}</div>
            <div class="label-price-row"><span class="label-price">R$ ${fmt(w.price)}</span><span class="label-stock-badge ${sc}">${st}</span></div>
            </div><div class="label-card-footer"><button class="btn-share-catalog" onclick="closeCatalog();openLabelPreview(${w.id})">📲 Enviar este rótulo</button></div>`;
        grid.appendChild(card);
    });
    document.getElementById('catalogOverlay').classList.add('open');
}
function closeCatalog(){document.getElementById('catalogOverlay').classList.remove('open');}

